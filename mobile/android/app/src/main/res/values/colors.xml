<?xml version="1.0" encoding="utf-8"?>
<!-- Click Assistant 液态玻璃色彩定义（浅色主题）
     与 WPF 端 App.xaml 保持语义一致 -->
<resources>
    <!-- 品牌主色 -->
    <color name="primary">#3978F6</color>
    <color name="primary_dark">#245CC7</color>
    <color name="primary_light">#DDEAFF</color>
    <color name="primary_gradient_start">#4C8DFF</color>
    <color name="primary_gradient_end">#5668D8</color>

    <!-- 辅助色 -->
    <color name="secondary">#0F9FA4</color>
    <color name="secondary_light">#D8F3F1</color>
    <color name="cyan">#168DA4</color>
    <color name="cyan_light">#DDF3F6</color>

    <!-- 文字色 -->
    <color name="text_primary">#17233A</color>
    <color name="text_secondary">#526176</color>
    <color name="text_muted">#8290A3</color>

    <!-- 背景与玻璃材质 -->
    <color name="bg_page_start">#E8F2F7</color>
    <color name="bg_page_mid">#F4F7FA</color>
    <color name="bg_page_end">#EEEAF6</color>
    <color name="bg_page">#EEF4F7</color>
    <color name="glass_card_top">#EEFFFFFF</color>
    <color name="glass_card_bottom">#BFFFFFFF</color>
    <color name="glass_nav_top">#F2FFFFFF</color>
    <color name="glass_nav_bottom">#CBEAF3F8</color>
    <color name="glass_subtle_top">#BFFFFFFF</color>
    <color name="glass_subtle_bottom">#8FEAF4F7</color>
    <color name="card_bg">#D9FFFFFF</color>
    <color name="gray_bg">#A6FFFFFF</color>
    <color name="border">#B8FFFFFF</color>
    <color name="border_light">#80FFFFFF</color>

    <!-- 语义状态色 -->
    <color name="success">#169B72</color>
    <color name="success_light">#D8F4E8</color>
    <color name="warning">#E98732</color>
    <color name="warning_light">#FFF0DB</color>
    <color name="danger">#D84D5F</color>
    <color name="danger_light">#FCE4E8</color>
    <color name="purple">#7067D8</color>
    <color name="purple_light">#E9E7FA</color>

    <!-- 系统栏 -->
    <color name="status_bar">#E8F2F7</color>
    <color name="nav_bar">#EEF4F7</color>
    <color name="window_bg">#EEF4F7</color>

    <!-- 背景光晕与玻璃泄漏 -->
    <color name="bg_glow_warm">#2DFFF0E0</color>   <!-- 右上暖光 18% -->
    <color name="bg_glow_cool">#18E0F0FF</color>   <!-- 左下冷光 10% -->
    <color name="glass_bleed">#123978F6</color>    <!-- 玻璃底部品牌蓝泄漏 7% -->

    <!-- 白色 -->
    <color name="white">#FFFFFF</color>
</resources>
