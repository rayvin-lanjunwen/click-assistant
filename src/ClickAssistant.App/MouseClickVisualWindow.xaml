<Window x:Class="ClickAssistant.App.MouseClickVisualWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="92"
        Height="92"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowActivated="False"
        ShowInTaskbar="False"
        IsHitTestVisible="False"
        Visibility="Hidden">
    <Grid x:Name="RootVisual"
          RenderTransformOrigin="0.5,0.5"
          Opacity="0">
        <Grid.RenderTransform>
            <ScaleTransform x:Name="RootScale" ScaleX="0.88" ScaleY="0.88" />
        </Grid.RenderTransform>

        <Ellipse x:Name="PulseRing"
                 Width="72"
                 Height="72"
                 HorizontalAlignment="Center"
                 VerticalAlignment="Center"
                 Stroke="#167C80"
                 StrokeThickness="3"
                 Opacity="0.58">
            <Ellipse.RenderTransform>
                <ScaleTransform x:Name="PulseScale" ScaleX="0.45" ScaleY="0.45" />
            </Ellipse.RenderTransform>
        </Ellipse>

        <Path x:Name="CursorShape"
              Margin="18,10,0,0"
              HorizontalAlignment="Left"
              VerticalAlignment="Top"
              Data="M 8 4 L 8 54 L 21 41 L 30 65 L 40 61 L 31 38 L 49 38 Z"
              Fill="#FFFFFF"
              Stroke="#172027"
              StrokeThickness="2">
            <Path.Effect>
                <DropShadowEffect BlurRadius="8"
                                  Direction="315"
                                  Opacity="0.35"
                                  ShadowDepth="2"
                                  Color="#172027" />
            </Path.Effect>
        </Path>
    </Grid>
</Window>
