<Window x:Class="ClickAssistant.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:ClickAssistant.App.Converters"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Click Assistant"
        Width="1180"
        Height="740"
        MinWidth="1040"
        MinHeight="660"
        WindowStartupLocation="CenterScreen"
        Background="#EEF3F5">
    <Window.Resources>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#1D252C" />
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#5B6975" />
        <SolidColorBrush x:Key="MutedBrush" Color="#EFF4F6" />
        <SolidColorBrush x:Key="PanelBrush" Color="#FCFEFF" />
        <SolidColorBrush x:Key="PanelBorderBrush" Color="#D4DEE6" />
        <SolidColorBrush x:Key="AccentBrush" Color="#167C80" />
        <SolidColorBrush x:Key="AccentDarkBrush" Color="#0E5659" />
        <SolidColorBrush x:Key="WarmBrush" Color="#C17F22" />
        <SolidColorBrush x:Key="DangerBrush" Color="#B44A45" />
        <converters:StepSummaryConverter x:Key="StepSummaryConverter" />

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="LogoMarkStyle" TargetType="Border">
            <Setter Property="Width" Value="54" />
            <Setter Property="Height" Value="54" />
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="CornerRadius" Value="8" />
        </Style>

        <Style x:Key="PanelStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PanelBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="18" />
        </Style>

        <Style x:Key="SubtlePanelStyle" TargetType="Border" BasedOn="{StaticResource PanelStyle}">
            <Setter Property="Background" Value="#F7FAFB" />
            <Setter Property="Padding" Value="14" />
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="MinHeight" Value="36" />
            <Setter Property="Padding" Value="16,7" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentDarkBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="MinHeight" Value="36" />
            <Setter Property="Padding" Value="14,7" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Background" Value="#F8FBFC" />
            <Setter Property="BorderBrush" Value="#C5D2DB" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style x:Key="DangerButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="Foreground" Value="{StaticResource DangerBrush}" />
        </Style>

        <Style x:Key="NavButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="Padding" Value="12,9" />
        </Style>

        <Style x:Key="ChoiceButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
            <Setter Property="MinHeight" Value="126" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Padding" Value="16" />
        </Style>

        <Style TargetType="TabControl">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="MinHeight" Value="36" />
            <Setter Property="Padding" Value="16,7" />
            <Setter Property="Margin" Value="0,0,6,0" />
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="BorderBrush" Value="#C7D3DC" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="#FBFDFE" />
        </Style>

        <Style TargetType="ListBox">
            <Setter Property="BorderBrush" Value="#D3DEE6" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="#FBFDFE" />
        </Style>
    </Window.Resources>

    <Grid>
        <ScrollViewer Padding="28"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <Grid>
                <Grid MinHeight="600" Visibility="{Binding HomePageVisibility}">
                    <StackPanel HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Width="360">
                        <Border HorizontalAlignment="Center" Style="{StaticResource LogoMarkStyle}">
                            <TextBlock HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontSize="22"
                                       FontWeight="Bold"
                                       Foreground="White"
                                       Text="CA" />
                        </Border>

                        <TextBlock Margin="0,18,0,0"
                                   HorizontalAlignment="Center"
                                   FontSize="34"
                                   FontWeight="SemiBold"
                                   Text="CLICK ASSISTANT" />
                        <TextBlock Margin="0,6,0,32"
                                   HorizontalAlignment="Center"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Text="点击与输入助手" />

                        <Button Margin="0"
                                Command="{Binding ShowNewTaskTypeCommand}"
                                Content="新建任务"
                                Style="{StaticResource PrimaryButtonStyle}" />
                        <Button Margin="0,12,0,0"
                                Command="{Binding ShowTaskLibraryCommand}"
                                Content="任务库"
                                Style="{StaticResource SecondaryButtonStyle}" />
                        <Button Margin="0,12,0,0"
                                Command="{Binding ShowExecutionLogsCommand}"
                                Content="执行日志"
                                Style="{StaticResource SecondaryButtonStyle}" />
                    </StackPanel>
                </Grid>

                <Grid Visibility="{Binding NewTaskTypePageVisibility}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="18" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0">
                        <Button DockPanel.Dock="Right"
                                Command="{Binding ShowHomeCommand}"
                                Content="返回首页"
                                Style="{StaticResource SecondaryButtonStyle}" />
                        <StackPanel>
                            <TextBlock FontSize="28" FontWeight="SemiBold" Text="新建任务" />
                            <TextBlock Margin="0,6,0,0"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Text="先选择任务类型。" />
                        </StackPanel>
                    </DockPanel>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="16" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Button Grid.Row="0"
                                Grid.Column="0"
                                Command="{Binding CreateMouseClickTaskCommand}"
                                Style="{StaticResource ChoiceButtonStyle}">
                            <StackPanel>
                                <TextBlock FontSize="20" FontWeight="SemiBold" Text="鼠标点击" />
                                <TextBlock Margin="0,8,0,0"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           Text="固定坐标点击、重复点击、开始延迟和点击间隔。" />
                                <TextBlock Margin="0,14,0,0"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource AccentDarkBrush}"
                                           Text="进入鼠标点击编辑页" />
                            </StackPanel>
                        </Button>

                        <Button Grid.Row="0"
                                Grid.Column="2"
                                Command="{Binding CreateKeyboardTaskCommand}"
                                Style="{StaticResource ChoiceButtonStyle}">
                            <StackPanel>
                                <TextBlock FontSize="20" FontWeight="SemiBold" Text="键盘按键" />
                                <TextBlock Margin="0,8,0,0"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           Text="单键或连续按键任务，适合重复触发快捷操作。" />
                                <TextBlock Margin="0,14,0,0"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource WarmBrush}"
                                           Text="先保存到任务库" />
                            </StackPanel>
                        </Button>

                        <Button Grid.Row="2"
                                Grid.Column="0"
                                Command="{Binding CreateTextInputTaskCommand}"
                                Style="{StaticResource ChoiceButtonStyle}">
                            <StackPanel>
                                <TextBlock FontSize="20" FontWeight="SemiBold" Text="文本输入" />
                                <TextBlock Margin="0,8,0,0"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           Text="保存常用文本，后续可扩展为输入模板。" />
                                <TextBlock Margin="0,14,0,0"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource WarmBrush}"
                                           Text="先保存到任务库" />
                            </StackPanel>
                        </Button>

                        <Button Grid.Row="2"
                                Grid.Column="2"
                                Command="{Binding CreateComboTaskCommand}"
                                Style="{StaticResource ChoiceButtonStyle}">
                            <StackPanel>
                                <TextBlock FontSize="20" FontWeight="SemiBold" Text="组合任务" />
                                <TextBlock Margin="0,8,0,0"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           Text="把鼠标、按键和文本组合成一组执行流程。" />
                                <TextBlock Margin="0,14,0,0"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource WarmBrush}"
                                           Text="先保存到任务库" />
                            </StackPanel>
                        </Button>
                    </Grid>
                </Grid>

                <Grid Visibility="{Binding TaskLibraryPageVisibility}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="18" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0">
                        <Button DockPanel.Dock="Right"
                                Command="{Binding ShowHomeCommand}"
                                Content="返回首页"
                                Style="{StaticResource SecondaryButtonStyle}" />
                        <StackPanel>
                            <TextBlock FontSize="28" FontWeight="SemiBold" Text="任务库" />
                            <TextBlock Margin="0,6,0,0"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Text="选择已保存任务后，可以编辑或执行。" />
                        </StackPanel>
                    </DockPanel>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="360" />
                            <ColumnDefinition Width="18" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Style="{StaticResource PanelStyle}">
                            <DockPanel LastChildFill="True">
                                <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
                                    <TextBlock FontSize="18" FontWeight="SemiBold" Text="已保存任务" />
                                    <Button Margin="0,12,0,0"
                                            Command="{Binding ShowNewTaskTypeCommand}"
                                            Content="新建任务"
                                            Style="{StaticResource PrimaryButtonStyle}" />
                                    <Button Margin="0,8,0,0"
                                            Command="{Binding DeleteTaskCommand}"
                                            Content="删除选中任务"
                                            Style="{StaticResource DangerButtonStyle}" />
                                </StackPanel>

                                <ListBox MinHeight="390"
                                         ItemsSource="{Binding Tasks}"
                                         SelectedItem="{Binding SelectedTask, Mode=TwoWay}">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="8">
                                                <TextBlock FontWeight="SemiBold" Text="{Binding Name}" />
                                                <TextBlock Margin="0,4,0,0"
                                                           Foreground="#5B6975"
                                                           Text="{Binding Description}" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </DockPanel>
                        </Border>

                        <Border Grid.Column="2" Style="{StaticResource PanelStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="16" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0">
                                    <TextBlock FontSize="22"
                                               FontWeight="SemiBold"
                                               Text="{Binding SelectedTask.Name}" />
                                    <TextBlock Margin="0,5,0,0"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               Text="{Binding SelectedTaskMetaText}" />
                                </StackPanel>

                                <TabControl Grid.Row="2" SelectedIndex="{Binding TaskLibrarySelectedTabIndex, Mode=TwoWay}">
                                    <TabItem Header="基础信息">
                                        <Grid Margin="0,14,0,0" IsEnabled="{Binding IsTaskEditorEnabled}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="16" />
                                        <ColumnDefinition Width="140" />
                                        <ColumnDefinition Width="16" />
                                        <ColumnDefinition Width="150" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="12" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="任务名称" />
                                    <TextBlock Grid.Row="0" Grid.Column="2" Text="重复次数" />
                                    <TextBlock Grid.Row="0" Grid.Column="4" Text="开始延迟（毫秒）" />

                                    <TextBox Grid.Row="1"
                                             Grid.Column="0"
                                             Margin="0,6,0,0"
                                             Text="{Binding SelectedTask.Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBox Grid.Row="1"
                                             Grid.Column="2"
                                             Margin="0,6,0,0"
                                             Text="{Binding SelectedTask.RepeatCount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBox Grid.Row="1"
                                             Grid.Column="4"
                                             Margin="0,6,0,0"
                                             Text="{Binding SelectedTask.StartDelayMs, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Grid.Row="2"
                                               Grid.Column="4"
                                               Margin="0,4,0,0"
                                               FontSize="12"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               Text="点开始后，等待多久再执行第一步。" />

                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="任务说明" />
                                     <TextBox Grid.Row="4"
                                             Grid.Column="0"
                                             Grid.ColumnSpan="5"
                                             Margin="0,6,0,0"
                                             MinHeight="64"
                                             AcceptsReturn="True"
                                             TextWrapping="Wrap"
                                             Text="{Binding SelectedTask.Description, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        </Grid>
                                    </TabItem>

                                    <TabItem Header="步骤设置">
                                        <Border Margin="0,14,0,0" Style="{StaticResource SubtlePanelStyle}">
                                    <Grid IsEnabled="{Binding IsTaskEditorEnabled}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="250" />
                                            <ColumnDefinition Width="18" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="12" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <DockPanel Grid.Row="0" Grid.ColumnSpan="3">
                                            <WrapPanel DockPanel.Dock="Right">
                                                <Button Command="{Binding AddStepCommand}"
                                                        Content="加鼠标"
                                                        Style="{StaticResource SecondaryButtonStyle}" />
                                                <Button Command="{Binding AddKeyboardStepCommand}"
                                                        Content="加按键"
                                                        Style="{StaticResource SecondaryButtonStyle}" />
                                                <Button Command="{Binding AddShortcutStepCommand}"
                                                        Content="加组合键"
                                                        Style="{StaticResource SecondaryButtonStyle}" />
                                                <Button Command="{Binding AddTextInputStepCommand}"
                                                        Content="加文本"
                                                        Style="{StaticResource SecondaryButtonStyle}" />
                                            </WrapPanel>
                                            <StackPanel>
                                                <TextBlock FontSize="18" FontWeight="SemiBold" Text="步骤配置" />
                                                <TextBlock Margin="0,4,0,0"
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           Text="已保存任务可在这里直接编辑步骤，保存后生效。" />
                                            </StackPanel>
                                        </DockPanel>

                                        <ListBox Grid.Row="2"
                                                 Grid.Column="0"
                                                 MinHeight="250"
                                                 ItemsSource="{Binding CurrentSteps}"
                                                 SelectedItem="{Binding SelectedStep, Mode=TwoWay}">
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel Margin="8">
                                                        <TextBlock FontWeight="SemiBold" Text="{Binding Name}" />
                                                        <TextBlock Margin="0,4,0,0"
                                                                   Foreground="#5B6975"
                                                                   Text="{Binding Converter={StaticResource StepSummaryConverter}}" />
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>

                                        <Grid Grid.Row="2" Grid.Column="2">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="12" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="12" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="12" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <Grid Grid.Row="0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="14" />
                                                    <ColumnDefinition Width="160" />
                                                    <ColumnDefinition Width="14" />
                                                    <ColumnDefinition Width="110" />
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>

                                                <TextBlock Grid.Row="0" Grid.Column="0" Text="步骤名称" />
                                                <TextBlock Grid.Row="0" Grid.Column="2" Text="动作类型" />
                                                <TextBlock Grid.Row="0" Grid.Column="4" Text="启用" />

                                                <TextBox Grid.Row="1"
                                                         Grid.Column="0"
                                                         Margin="0,6,0,0"
                                                         Text="{Binding SelectedStepName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                <ComboBox Grid.Row="1"
                                                          Grid.Column="2"
                                                          Margin="0,6,0,0"
                                                          MinHeight="34"
                                                          ItemsSource="{Binding InputActionTypeOptions}"
                                                          DisplayMemberPath="DisplayName"
                                                          SelectedValuePath="Value"
                                                          SelectedValue="{Binding SelectedStepActionType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                <CheckBox Grid.Row="1"
                                                          Grid.Column="4"
                                                          Margin="0,13,0,0"
                                                          IsChecked="{Binding SelectedStepEnabled, Mode=TwoWay}" />
                                            </Grid>

                                            <Grid Grid.Row="2">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="150" />
                                                    <ColumnDefinition Width="14" />
                                                    <ColumnDefinition Width="150" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>

                                                <TextBlock Grid.Row="0" Grid.Column="0" Text="步骤前等待（毫秒）" />
                                                <TextBlock Grid.Row="0" Grid.Column="2" Text="步骤后等待（毫秒）" />
                                                <TextBox Grid.Row="1"
                                                         Grid.Column="0"
                                                         Margin="0,6,0,0"
                                                         Text="{Binding SelectedStepBeforeDelayMs, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                <TextBox Grid.Row="1"
                                                         Grid.Column="2"
                                                         Margin="0,6,0,0"
                                                         Text="{Binding SelectedStepAfterDelayMs, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                <TextBlock Grid.Row="2"
                                                           Grid.Column="2"
                                                           Grid.ColumnSpan="2"
                                                           Margin="0,4,0,0"
                                                           FontSize="12"
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           Text="点击间隔：本次点击后等待多久，再执行下一步或下一次循环。" />
                                            </Grid>

                                            <Grid Grid.Row="4" Visibility="{Binding MouseStepFieldsVisibility}">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="100" />
                                                    <ColumnDefinition Width="12" />
                                                    <ColumnDefinition Width="100" />
                                                    <ColumnDefinition Width="12" />
                                                    <ColumnDefinition Width="110" />
                                                    <ColumnDefinition Width="12" />
                                                    <ColumnDefinition Width="150" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>

                                                <TextBlock Grid.Row="0" Grid.Column="0" Text="X 坐标" />
                                                <TextBlock Grid.Row="0" Grid.Column="2" Text="Y 坐标" />
                                                <TextBlock Grid.Row="0" Grid.Column="4" Text="点击次数" />
                                                <TextBlock Grid.Row="0" Grid.Column="6" Text="点击方式" />
                                                <TextBox Grid.Row="1"
                                                         Grid.Column="0"
                                                         Margin="0,6,0,0"
                                                         Text="{Binding SelectedStepX, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                <TextBox Grid.Row="1"
                                                         Grid.Column="2"
                                                         Margin="0,6,0,0"
                                                         Text="{Binding SelectedStepY, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                <TextBox Grid.Row="1"
                                                         Grid.Column="4"
                                                         Margin="0,6,0,0"
                                                         Text="{Binding SelectedStepMouseClickCount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                <ComboBox Grid.Row="1"
                                                          Grid.Column="6"
                                                          Margin="0,6,0,0"
                                                          MinHeight="34"
                                                          ItemsSource="{Binding ClickTypeOptions}"
                                                          DisplayMemberPath="DisplayName"
                                                          SelectedValuePath="Value"
                                                          SelectedValue="{Binding SelectedStepClickType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                <WrapPanel Grid.Row="1"
                                                           Grid.Column="7"
                                                           Margin="14,6,0,0">
                                                    <Button Command="{Binding CaptureCoordinateCommand}"
                                                            Content="选择坐标"
                                                            Style="{StaticResource SecondaryButtonStyle}" />
                                                    <Button Command="{Binding TestMouseClickCommand}"
                                                            Content="测试点击"
                                                            Style="{StaticResource SecondaryButtonStyle}" />
                                                </WrapPanel>
                                            </Grid>

                                            <Grid Grid.Row="4" Visibility="{Binding KeyboardStepFieldsVisibility}">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="14" />
                                                    <ColumnDefinition Width="130" />
                                                    <ColumnDefinition Width="14" />
                                                    <ColumnDefinition Width="150" />
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>

                                                <Border Grid.Row="0"
                                                        Grid.RowSpan="2"
                                                        Grid.Column="0"
                                                        Padding="14"
                                                        Background="#EAF5F5"
                                                        BorderBrush="#A7CDD0"
                                                        BorderThickness="1"
                                                        CornerRadius="8">
                                                    <StackPanel>
                                                        <TextBlock FontSize="12"
                                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                                   Text="按键捕获" />
                                                        <TextBlock Margin="0,8,0,0"
                                                                   FontSize="22"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{StaticResource AccentDarkBrush}"
                                                                   Text="{Binding SelectedStepKeyDisplayText}" />
                                                        <TextBox x:Name="KeyboardCaptureTextBox"
                                                                 Margin="0,12,0,0"
                                                                 Cursor="Hand"
                                                                 Focusable="True"
                                                                 GotKeyboardFocus="HandleKeyboardCaptureGotKeyboardFocus"
                                                                 IsReadOnly="True"
                                                                 LostKeyboardFocus="HandleKeyboardCaptureLostKeyboardFocus"
                                                                 PreviewKeyDown="HandleKeyboardCapturePreviewKeyDown"
                                                                 PreviewMouseLeftButtonDown="HandleKeyboardCapturePreviewMouseLeftButtonDown"
                                                                 Text="{Binding SelectedStepKeyName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                        <TextBlock Margin="0,8,0,0"
                                                                   FontSize="12"
                                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                                   Text="{Binding KeyboardCaptureStatus}" />
                                                    </StackPanel>
                                                </Border>

                                                <TextBlock Grid.Row="0" Grid.Column="2" Text="连按次数" />
                                                <TextBlock Grid.Row="0" Grid.Column="4" Text="连按间隔（毫秒）" />
                                                <TextBox Grid.Row="1"
                                                         Grid.Column="2"
                                                         Margin="0,6,0,0"
                                                         Text="{Binding SelectedStepKeyPressCount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                <TextBox Grid.Row="1"
                                                         Grid.Column="4"
                                                         Margin="0,6,0,0"
                                                         Text="{Binding SelectedStepKeyIntervalMs, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                            </Grid>

                                            <Grid Grid.Row="4" Visibility="{Binding ShortcutStepFieldsVisibility}">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>

                                                <TextBlock Text="组合键" />
                                                <TextBox Grid.Row="1"
                                                         Margin="0,6,0,0"
                                                         Text="{Binding SelectedStepShortcutKeys, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                            </Grid>

                                            <Grid Grid.Row="4" Visibility="{Binding TextInputStepFieldsVisibility}">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="14" />
                                                    <ColumnDefinition Width="150" />
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>

                                                <TextBlock Grid.Row="0" Grid.Column="0" Text="文本内容" />
                                                <TextBlock Grid.Row="0" Grid.Column="2" Text="字符间隔（毫秒）" />
                                                <TextBox Grid.Row="1"
                                                         Grid.Column="0"
                                                         Margin="0,6,0,0"
                                                         MinHeight="78"
                                                         AcceptsReturn="True"
                                                         TextWrapping="Wrap"
                                                         Text="{Binding SelectedStepTextContent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                <TextBox Grid.Row="1"
                                                         Grid.Column="2"
                                                         Margin="0,6,0,0"
                                                         Text="{Binding SelectedStepKeyIntervalMs, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                            </Grid>

                                            <Button Grid.Row="6"
                                                    Command="{Binding RemoveStepCommand}"
                                                    Content="删除当前步骤"
                                                    Style="{StaticResource DangerButtonStyle}" />
                                        </Grid>
                                    </Grid>
                                        </Border>
                                    </TabItem>

                                    <TabItem Header="执行确认">
                                        <StackPanel Margin="0,14,0,0">
                                            <TextBlock FontSize="18" FontWeight="SemiBold" Text="执行前确认" />
                                            <TextBlock Margin="0,6,0,0"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       Text="{Binding ExecutionSummary}" />
                                            <TextBlock Margin="0,10,0,0"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       Text="{Binding ExecutionSafetyText}" />
                                            <TextBlock Margin="0,10,0,0"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       Text="{Binding HotkeyStatus}" />

                                            <WrapPanel Margin="0,18,0,0">
                                    <Button Command="{Binding ShowMouseClickEditorCommand}"
                                            Content="鼠标专页"
                                            Style="{StaticResource PrimaryButtonStyle}" />
                                    <Button Command="{Binding SaveTaskCommand}"
                                            Content="保存修改"
                                            Style="{StaticResource SecondaryButtonStyle}" />
                                    <Button Command="{Binding StartCommand}"
                                            Content="执行"
                                            Style="{StaticResource SecondaryButtonStyle}" />
                                    <Button Command="{Binding DuplicateTaskCommand}"
                                            Content="复制"
                                            Style="{StaticResource SecondaryButtonStyle}" />
                                    <Button Command="{Binding DeleteTaskCommand}"
                                            Content="删除"
                                            Style="{StaticResource DangerButtonStyle}" />
                                            </WrapPanel>
                                        </StackPanel>
                                    </TabItem>
                                </TabControl>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>

                <Grid Visibility="{Binding ExecutionLogsPageVisibility}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="18" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0">
                        <Button DockPanel.Dock="Right"
                                Command="{Binding ShowHomeCommand}"
                                Content="返回首页"
                                Style="{StaticResource SecondaryButtonStyle}" />
                        <StackPanel>
                            <TextBlock FontSize="28" FontWeight="SemiBold" Text="执行日志" />
                            <TextBlock Margin="0,6,0,0"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Text="最近执行结果和本次运行记录。" />
                        </StackPanel>
                    </DockPanel>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="18" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Style="{StaticResource PanelStyle}">
                            <DockPanel LastChildFill="True">
                                <TextBlock DockPanel.Dock="Top"
                                           Margin="0,0,0,12"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           Text="最近执行结果" />
                                <ListBox MinHeight="430" ItemsSource="{Binding RecentLogs}" />
                            </DockPanel>
                        </Border>

                        <Border Grid.Column="2" Style="{StaticResource PanelStyle}">
                            <DockPanel LastChildFill="True">
                                <TextBlock DockPanel.Dock="Top"
                                           Margin="0,0,0,12"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           Text="本次运行记录" />
                                <ListBox MinHeight="430" ItemsSource="{Binding RuntimeLogs}" />
                            </DockPanel>
                        </Border>
                    </Grid>
                </Grid>

                <Grid Visibility="{Binding MouseClickEditorPageVisibility}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="18" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="18" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0">
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                            <Button Command="{Binding ShowHomeCommand}"
                                    Content="返回首页"
                                    Style="{StaticResource SecondaryButtonStyle}" />
                            <Button Command="{Binding ShowTaskLibraryCommand}"
                                    Content="返回任务库"
                                    Style="{StaticResource SecondaryButtonStyle}" />
                        </StackPanel>
                        <StackPanel>
                            <TextBlock FontSize="28" FontWeight="SemiBold" Text="鼠标点击任务编辑" />
                            <TextBlock Margin="0,6,0,0"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Text="配置固定坐标、点击次数、开始延迟和点击间隔。运行中请用悬浮窗暂停或停止。" />
                        </StackPanel>
                    </DockPanel>

                    <Border Grid.Row="2" Style="{StaticResource PanelStyle}">
                        <Grid IsEnabled="{Binding IsTaskEditorEnabled}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="300" />
                                <ColumnDefinition Width="18" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="18" />
                                <ColumnDefinition Width="260" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock FontSize="16" FontWeight="SemiBold" Text="点击位置（按顺序执行）" />
                                <TextBlock Margin="0,6,0,0"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           TextWrapping="Wrap"
                                           Text="{Binding MousePositionSummary}" />

                                <ListBox Margin="0,12,0,0"
                                         MinHeight="230"
                                         ItemsSource="{Binding MouseSteps}"
                                         SelectedItem="{Binding SelectedStep, Mode=TwoWay}">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="4">
                                                <TextBlock FontWeight="SemiBold" Text="{Binding Name}" />
                                                <TextBlock Margin="0,4,0,0"
                                                           FontSize="12"
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           Text="{Binding Converter={StaticResource StepSummaryConverter}}" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>

                                <WrapPanel Margin="0,12,0,0">
                                    <Button Command="{Binding AddStepCommand}"
                                            Content="添加位置"
                                            Style="{StaticResource PrimaryButtonStyle}" />
                                    <Button Command="{Binding MoveStepUpCommand}"
                                            Content="上移"
                                            Style="{StaticResource SecondaryButtonStyle}" />
                                    <Button Command="{Binding MoveStepDownCommand}"
                                            Content="下移"
                                            Style="{StaticResource SecondaryButtonStyle}" />
                                    <Button Command="{Binding RemoveStepCommand}"
                                            Content="删除位置"
                                            Style="{StaticResource DangerButtonStyle}" />
                                </WrapPanel>
                            </StackPanel>

                            <Grid Grid.Column="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="140" />
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="160" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="12" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="18" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="18" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="任务名称" />
                                <TextBlock Grid.Row="0" Grid.Column="2" Text="执行轮数" />
                                <TextBlock Grid.Row="0" Grid.Column="4" Text="开始延迟（毫秒）" />

                                <TextBox Grid.Row="1"
                                         Grid.Column="0"
                                         Margin="0,6,0,0"
                                         Text="{Binding MouseTaskName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBox Grid.Row="1"
                                         Grid.Column="2"
                                         Margin="0,6,0,0"
                                         Text="{Binding MouseRepeatCount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBox Grid.Row="1"
                                         Grid.Column="4"
                                         Margin="0,6,0,0"
                                         Text="{Binding MouseStartDelayMs, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                                <TextBlock Grid.Row="3" Grid.Column="0" Text="任务说明" />
                                <TextBox Grid.Row="4"
                                         Grid.Column="0"
                                         Grid.ColumnSpan="5"
                                         Margin="0,6,0,0"
                                         MinHeight="64"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         Text="{Binding MouseTaskDescription, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                                <TextBlock Grid.Row="6"
                                           Grid.ColumnSpan="5"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Text="当前选中位置" />

                                <Grid Grid.Row="7" Grid.ColumnSpan="5" Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="110" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="110" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="120" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="12" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="位置名称" />
                                    <TextBlock Grid.Row="0" Grid.Column="2" Text="X 坐标" />
                                    <TextBlock Grid.Row="0" Grid.Column="4" Text="Y 坐标" />
                                    <TextBlock Grid.Row="0" Grid.Column="6" Text="点击次数" />

                                    <TextBox Grid.Row="1"
                                             Grid.Column="0"
                                             Margin="0,6,0,0"
                                             Text="{Binding SelectedStepName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBox Grid.Row="1"
                                             Grid.Column="2"
                                             Margin="0,6,0,0"
                                             Text="{Binding MouseX, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBox Grid.Row="1"
                                             Grid.Column="4"
                                             Margin="0,6,0,0"
                                             Text="{Binding MouseY, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBox Grid.Row="1"
                                              Grid.Column="6"
                                              Margin="0,6,0,0"
                                             Text="{Binding MouseClickCount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="点击间隔（毫秒）" />
                                    <TextBlock Grid.Row="3" Grid.Column="2" Text="点击方式" />

                                    <TextBox Grid.Row="4"
                                             Grid.Column="0"
                                             Margin="0,6,0,0"
                                             Text="{Binding MouseClickIntervalMs, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <ComboBox Grid.Row="4"
                                              Grid.Column="2"
                                              Grid.ColumnSpan="3"
                                              Margin="0,6,0,0"
                                              MinHeight="34"
                                              ItemsSource="{Binding ClickTypeOptions}"
                                              DisplayMemberPath="DisplayName"
                                              SelectedValuePath="Value"
                                              SelectedValue="{Binding MouseClickType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </Grid>
                            </Grid>

                            <Border Grid.Column="4"
                                    Background="{StaticResource MutedBrush}"
                                    BorderBrush="{StaticResource PanelBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="14">
                                <StackPanel>
                                    <TextBlock FontSize="16" FontWeight="SemiBold" Text="坐标采集" />
                                    <TextBlock Margin="0,6,0,12"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               Text="{Binding CoordinateCaptureStatus}" />
                                    <TextBlock FontWeight="SemiBold"
                                               Foreground="{StaticResource AccentDarkBrush}"
                                               Text="{Binding MouseClickTypeText}" />
                                    <Button Margin="0,16,0,0"
                                            Command="{Binding CaptureCoordinateCommand}"
                                            Content="选择坐标"
                                            Style="{StaticResource SecondaryButtonStyle}" />
                                    <Button Margin="0,8,0,0"
                                            Command="{Binding TestMouseClickCommand}"
                                            Content="测试点击一次"
                                            Style="{StaticResource SecondaryButtonStyle}" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>

                    <Border Grid.Row="4" Style="{StaticResource PanelStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="260" />
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <TextBlock FontSize="18" FontWeight="SemiBold" Text="执行摘要" />
                                <TextBlock Margin="0,8,0,0"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           Text="{Binding ExecutionSummary}" />
                                <TextBlock Margin="0,12,0,0"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource DangerBrush}"
                                           Text="{Binding ExecutionSafetyText}" />
                            </StackPanel>

                            <StackPanel Grid.Column="1">
                                <Button Command="{Binding SaveTaskCommand}"
                                        Content="保存任务"
                                        Style="{StaticResource PrimaryButtonStyle}" />
                                <WrapPanel Margin="0,12,0,0">
                                    <Button Command="{Binding StartCommand}"
                                            Content="开始执行"
                                            Style="{StaticResource PrimaryButtonStyle}" />
                                    <Button Command="{Binding PauseCommand}"
                                            Content="暂停"
                                            Style="{StaticResource SecondaryButtonStyle}" />
                                    <Button Command="{Binding ResumeCommand}"
                                            Content="继续"
                                            Style="{StaticResource SecondaryButtonStyle}" />
                                    <Button Command="{Binding StopCommand}"
                                            Content="停止"
                                            Style="{StaticResource DangerButtonStyle}" />
                                </WrapPanel>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </ScrollViewer>
    </Grid>
</Window>
