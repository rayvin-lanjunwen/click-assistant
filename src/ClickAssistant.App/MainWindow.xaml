<Window x:Class="ClickAssistant.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Click Assistant"
        Width="1180"
        Height="720"
        MinWidth="1040"
        MinHeight="640"
        WindowStartupLocation="CenterScreen"
        Background="#F2F6F8">
    <Window.Resources>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#1D252C" />
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#5B6975" />
        <SolidColorBrush x:Key="PanelBrush" Color="#EFFFFFFF" />
        <SolidColorBrush x:Key="PanelBorderBrush" Color="#D6E0E7" />
        <SolidColorBrush x:Key="AccentBrush" Color="#167C80" />
        <SolidColorBrush x:Key="AccentDarkBrush" Color="#0E5659" />
        <SolidColorBrush x:Key="DangerBrush" Color="#B44A45" />

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="PanelStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PanelBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="16" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="22"
                                      Direction="270"
                                      Opacity="0.16"
                                      ShadowDepth="4"
                                      Color="#AAB6C1" />
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Padding" Value="14,6" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentDarkBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Background" Value="#F8FBFC" />
            <Setter Property="BorderBrush" Value="#CBD6DE" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style x:Key="DangerButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="Foreground" Value="{StaticResource DangerBrush}" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="BorderBrush" Value="#C7D3DC" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="#FBFDFE" />
        </Style>

        <Style TargetType="ListBox">
            <Setter Property="BorderBrush" Value="#D3DEE6" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="#FBFDFE" />
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="BorderBrush" Value="#D3DEE6" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="RowHeaderWidth" Value="0" />
            <Setter Property="CanUserAddRows" Value="False" />
            <Setter Property="AutoGenerateColumns" Value="False" />
            <Setter Property="Background" Value="#FBFDFE" />
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,14">
            <StackPanel DockPanel.Dock="Left">
                <TextBlock FontSize="24" FontWeight="SemiBold" Text="Click Assistant" />
                <TextBlock Margin="0,4,0,0"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Text="首版支持 Windows 鼠标点击和键盘连按任务。" />
            </StackPanel>

            <Border DockPanel.Dock="Right"
                    MinWidth="132"
                    Padding="12,8"
                    HorizontalAlignment="Right"
                    Background="#DDF6FBFA"
                    BorderBrush="#B8D8D8"
                    BorderThickness="1"
                    CornerRadius="8">
                <StackPanel>
                    <TextBlock FontSize="12"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Text="执行状态" />
                    <TextBlock FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource AccentDarkBrush}"
                               Text="{Binding StatusText}" />
                </StackPanel>
            </Border>
        </DockPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="300" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource PanelStyle}">
                <DockPanel LastChildFill="True">
                    <StackPanel DockPanel.Dock="Top">
                        <TextBlock FontSize="16" FontWeight="SemiBold" Text="任务" />
                        <TextBlock Margin="0,4,0,12"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Text="选择或创建点击任务。" />
                        <WrapPanel Margin="0,0,0,10">
                            <Button Command="{Binding CreateTaskCommand}"
                                    Content="新建"
                                    Style="{StaticResource PrimaryButtonStyle}" />
                            <Button Command="{Binding DuplicateTaskCommand}"
                                    Content="复制"
                                    Style="{StaticResource SecondaryButtonStyle}" />
                            <Button Command="{Binding DeleteTaskCommand}"
                                    Content="删除"
                                    Style="{StaticResource DangerButtonStyle}" />
                        </WrapPanel>
                    </StackPanel>

                    <ListBox ItemsSource="{Binding Tasks}"
                             SelectedItem="{Binding SelectedTask, Mode=TwoWay}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="6">
                                    <TextBlock FontWeight="SemiBold" Text="{Binding Name}" />
                                    <TextBlock Margin="0,3,0,0"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               Text="{Binding Description}" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource PanelStyle}">
                <DockPanel LastChildFill="True" IsEnabled="{Binding IsTaskEditorEnabled}">
                    <StackPanel DockPanel.Dock="Top">
                        <TextBlock FontSize="16" FontWeight="SemiBold" Text="任务配置" />
                        <Grid Margin="0,14,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="130" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="150" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="任务名称" />
                            <TextBlock Grid.Row="0" Grid.Column="2" Text="重复次数" />
                            <TextBlock Grid.Row="0" Grid.Column="4" Text="开始延迟（毫秒）" />

                            <TextBox Grid.Row="1"
                                     Grid.Column="0"
                                     Margin="0,6,0,0"
                                     Text="{Binding SelectedTask.Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBox Grid.Row="1"
                                     Grid.Column="2"
                                     Margin="0,6,0,0"
                                     Text="{Binding SelectedTask.RepeatCount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBox Grid.Row="1"
                                     Grid.Column="4"
                                     Margin="0,6,0,0"
                                     Text="{Binding SelectedTask.StartDelayMs, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </Grid>

                        <TextBlock Text="任务说明" />
                        <TextBox Margin="0,6,0,12"
                                 MinHeight="58"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 Text="{Binding SelectedTask.Description, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <WrapPanel Margin="0,0,0,10">
                            <CheckBox Margin="0,8,16,0"
                                      VerticalAlignment="Center"
                                      Content="启用任务"
                                      IsChecked="{Binding SelectedTask.Enabled, Mode=TwoWay}" />
                            <Button Command="{Binding AddStepCommand}"
                                    Content="添加鼠标步骤"
                                    Style="{StaticResource SecondaryButtonStyle}" />
                            <Button Command="{Binding AddKeyboardStepCommand}"
                                    Content="添加键盘步骤"
                                    Style="{StaticResource SecondaryButtonStyle}" />
                            <Button Command="{Binding CaptureCoordinateCommand}"
                                    Content="捕获坐标"
                                    Style="{StaticResource SecondaryButtonStyle}" />
                            <Button Command="{Binding RemoveStepCommand}"
                                    Content="移除步骤"
                                    Style="{StaticResource DangerButtonStyle}" />
                            <Button Command="{Binding SaveTaskCommand}"
                                    Content="保存"
                                    Style="{StaticResource PrimaryButtonStyle}" />
                        </WrapPanel>
                    </StackPanel>

                    <DataGrid ItemsSource="{Binding CurrentSteps}"
                              ScrollViewer.HorizontalScrollBarVisibility="Auto"
                              SelectedItem="{Binding SelectedStep, Mode=TwoWay}">
                        <DataGrid.Columns>
                            <DataGridCheckBoxColumn Width="62"
                                                    Header="启用"
                                                    Binding="{Binding Enabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <DataGridTextColumn Width="132"
                                                Header="步骤名称"
                                                Binding="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <DataGridTemplateColumn Width="112" Header="动作类型">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <ComboBox Margin="2"
                                                  ItemsSource="{Binding DataContext.InputActionTypeOptions, RelativeSource={RelativeSource AncestorType=Window}}"
                                                  DisplayMemberPath="DisplayName"
                                                  SelectedValuePath="Value"
                                                  SelectedValue="{Binding ActionType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Width="72"
                                                Header="X"
                                                Binding="{Binding X, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <DataGridTextColumn Width="72"
                                                Header="Y"
                                                Binding="{Binding Y, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <DataGridTemplateColumn Width="122" Header="点击类型">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <ComboBox Margin="2"
                                                  ItemsSource="{Binding DataContext.ClickTypeOptions, RelativeSource={RelativeSource AncestorType=Window}}"
                                                  DisplayMemberPath="DisplayName"
                                                  SelectedValuePath="Value"
                                                  SelectedValue="{Binding ClickType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Width="92"
                                                Header="按键"
                                                Binding="{Binding KeyName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <DataGridTextColumn Width="82"
                                                Header="连按"
                                                Binding="{Binding KeyPressCount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <DataGridTextColumn Width="96"
                                                Header="键间隔"
                                                Binding="{Binding KeyIntervalMs, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <DataGridTextColumn Width="112"
                                                Header="前等待"
                                                Binding="{Binding BeforeDelayMs, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <DataGridTextColumn Width="112"
                                                Header="后等待"
                                                Binding="{Binding AfterDelayMs, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>

            <Border Grid.Column="4" Style="{StaticResource PanelStyle}">
                <DockPanel LastChildFill="True">
                    <StackPanel DockPanel.Dock="Top">
                        <TextBlock FontSize="16" FontWeight="SemiBold" Text="执行" />
                        <TextBlock Margin="0,4,0,12"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Text="启动前会自动保存当前任务配置。" />
                        <TextBlock Margin="0,0,0,12"
                                   Foreground="{StaticResource AccentDarkBrush}"
                                   Text="{Binding HotkeyStatus}" />
                        <TextBlock Margin="0,0,0,12"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource DangerBrush}"
                                   Text="{Binding ExecutionSafetyText}" />
                        <TextBlock Text="停止快捷键" />
                        <Grid Margin="0,6,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="92" />
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0"
                                     Text="{Binding StopHotkeyInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <Button Grid.Column="2"
                                    Command="{Binding SaveStopHotkeyCommand}"
                                    Content="保存"
                                    Style="{StaticResource SecondaryButtonStyle}" />
                        </Grid>
                        <WrapPanel Margin="0,0,0,14">
                            <Button Command="{Binding StartCommand}"
                                    Content="启动"
                                    Style="{StaticResource PrimaryButtonStyle}" />
                            <Button Command="{Binding PauseCommand}"
                                    Content="暂停"
                                    Style="{StaticResource SecondaryButtonStyle}" />
                            <Button Command="{Binding ResumeCommand}"
                                    Content="继续"
                                    Style="{StaticResource SecondaryButtonStyle}" />
                            <Button Command="{Binding StopCommand}"
                                    Content="停止"
                                    Style="{StaticResource DangerButtonStyle}" />
                        </WrapPanel>
                    </StackPanel>

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="16" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <DockPanel Grid.Row="0">
                            <TextBlock DockPanel.Dock="Top"
                                       Margin="0,0,0,8"
                                       FontWeight="SemiBold"
                                       Text="实时日志" />
                            <ListBox ItemsSource="{Binding RuntimeLogs}" />
                        </DockPanel>

                        <DockPanel Grid.Row="2">
                            <TextBlock DockPanel.Dock="Top"
                                       Margin="0,0,0,8"
                                       FontWeight="SemiBold"
                                       Text="最近执行" />
                            <ListBox ItemsSource="{Binding RecentLogs}" />
                        </DockPanel>
                    </Grid>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
