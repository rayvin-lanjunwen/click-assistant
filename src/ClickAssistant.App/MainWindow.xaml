<Window x:Class="ClickAssistant.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:ClickAssistant.App"
        xmlns:converters="clr-namespace:ClickAssistant.App.Converters"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Click Assistant"
        Width="1200"
        Height="760"
        MinWidth="1080"
        MinHeight="680"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BgPrimaryBrush}">
    <Window.Resources>
        <!-- 颜色与共享转换器已迁移到 App.xaml 的 Application.Resources，
             所有窗口（包括独立窗口）均可见。-->

        <!-- ===== 共享动画缓动函数 ===== -->
        <QuadraticEase x:Key="EaseOutQuad" EasingMode="EaseOut" />
        <QuadraticEase x:Key="EaseInOutQuad" EasingMode="EaseInOut" />
        <BackEase x:Key="EaseOutBack" EasingMode="EaseOut" Amplitude="0.3" />
        <ElasticEase x:Key="EaseOutElastic" EasingMode="EaseOut" Oscillations="1" Springiness="3" />

        <!-- 基础 TextBlock -->
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="FontFamily" Value="Microsoft YaHei UI" />
        </Style>

        <!-- ===== 液态玻璃三阶阴影系统 ===== -->
        <!-- L1 表层：小控件、Badge、Switch -->
        <DropShadowEffect x:Key="ShadowSm"
                          BlurRadius="8" ShadowDepth="3" Direction="270"
                          Color="#26334A" Opacity="0.08" />

        <!-- L2 中景：普通卡片（增强版，替代原 GlassShadowEffect） -->
        <DropShadowEffect x:Key="ShadowMd"
                          BlurRadius="16" ShadowDepth="6" Direction="270"
                          Color="#26334A" Opacity="0.13" />

        <!-- L3 深层：导航栏、弹窗、悬浮窗 -->
        <DropShadowEffect x:Key="ShadowLg"
                          BlurRadius="32" ShadowDepth="14" Direction="270"
                          Color="#26334A" Opacity="0.18" />

        <!-- 卡片面板（液态玻璃 + Specular 高光层 + 三阶阴影） -->
        <Style x:Key="CardStyle" TargetType="local:GlassCard">
            <Setter Property="Background" Value="{DynamicResource BgCardBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="16" />
            <Setter Property="Padding" Value="20" />
            <Setter Property="Effect" Value="{DynamicResource ShadowMd}" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="local:GlassCard">
                        <Grid>
                            <!-- ① 阴影层：通过 TemplateBinding Effect 控制，
                                 SubtleCardStyle（Effect=null）自动无阴影 -->
                            <Border Margin="0,6,0,0"
                                    CornerRadius="{TemplateBinding CornerRadius}"
                                    Background="Transparent"
                                    Effect="{TemplateBinding Effect}" />

                            <!-- ② 玻璃基底 + 内容 -->
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="{TemplateBinding CornerRadius}"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter />
                            </Border>

                            <!-- ③ 内高光层：左上亮边，模拟玻璃反射 -->
                            <Border CornerRadius="{TemplateBinding CornerRadius}"
                                    BorderBrush="#60FFFFFF"
                                    BorderThickness="1,1,0,0"
                                    IsHitTestVisible="False" />

                            <!-- ④ 底部品牌蓝光晕泄漏：模拟环境光在天蓝玻璃底部的折射 -->
                            <Border CornerRadius="{TemplateBinding CornerRadius}"
                                    VerticalAlignment="Bottom"
                                    Height="6"
                                    Background="{DynamicResource GlassBleedBrush}"
                                    IsHitTestVisible="False" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SubtleCardStyle" TargetType="local:GlassCard" BasedOn="{StaticResource CardStyle}">
            <Setter Property="Background" Value="{DynamicResource GlassSubtleBrush}" />
            <Setter Property="Padding" Value="16" />
            <Setter Property="Effect" Value="{x:Null}" />
        </Style>

        <Style x:Key="HighlightCardStyle" TargetType="local:GlassCard" BasedOn="{StaticResource CardStyle}">
            <Setter Property="Background" Value="#C9E4EEFF" />
            <Setter Property="BorderBrush" Value="#D6FFFFFF" />
            <Setter Property="Padding" Value="16" />
        </Style>

        <!-- 按钮 - 主按钮（液态玻璃光泽扫过效果） -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="MinHeight" Value="40" />
            <Setter Property="Padding" Value="20,9" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="{DynamicResource PrimaryGradientBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource PrimaryDarkBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <!-- 按钮背景 -->
                            <Border x:Name="RootBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="10"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <!-- 光泽层（hover 时滑入循环） -->
                            <Border x:Name="ShineBorder"
                                    CornerRadius="10"
                                    IsHitTestVisible="False"
                                    Opacity="0">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Offset="-0.3" Color="Transparent" />
                                        <GradientStop Offset="0.5" Color="#60FFFFFF" />
                                        <GradientStop Offset="1.3" Color="Transparent" />
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <!-- 光泽划过循环 -->
                                            <ThicknessAnimation Storyboard.TargetName="ShineBorder"
                                                                Storyboard.TargetProperty="Margin"
                                                                From="-200,0,200,0" To="200,0,-200,0"
                                                                Duration="0:0:0.6"
                                                                AutoReverse="False"
                                                                RepeatBehavior="Forever"
                                                                EasingFunction="{StaticResource EaseInOutQuad}" />
                                            <DoubleAnimation Storyboard.TargetName="ShineBorder"
                                                             Storyboard.TargetProperty="Opacity"
                                                             From="0" To="1"
                                                             Duration="0:0:0.15" />
                                            <DoubleAnimation Storyboard.TargetName="RootBorder"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="0.85"
                                                             Duration="0:0:0.15"
                                                             EasingFunction="{StaticResource EaseOutQuad}" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ShineBorder"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="0"
                                                             Duration="0:0:0.2" />
                                            <DoubleAnimation Storyboard.TargetName="RootBorder"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="1"
                                                             Duration="0:0:0.2"
                                                             EasingFunction="{StaticResource EaseOutQuad}" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.5" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 按钮 - 次要按钮 -->
        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="MinHeight" Value="40" />
            <Setter Property="Padding" Value="16,9" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="Background" Value="#AFFFFFFF" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E6FFFFFF" />
                    <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.5" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 按钮 - 危险按钮 -->
        <Style x:Key="DangerButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="Foreground" Value="{StaticResource DangerBrush}" />
            <Setter Property="BorderBrush" Value="#FECACA" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource DangerLightBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 按钮 - 链接文本 -->
        <Style x:Key="LinkButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <TextBlock Text="{TemplateBinding Content}"
                                   Foreground="{TemplateBinding Foreground}"
                                   Cursor="Hand" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 选择卡片按钮（hover 上浮 4px） -->
        <Style x:Key="ChoiceButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
            <Setter Property="MinHeight" Value="140" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Padding" Value="20" />
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <TranslateTransform />
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Trigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.Y"
                                                 To="-4" Duration="0:0:0.2"
                                                 EasingFunction="{StaticResource EaseOutQuad}" />
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.EnterActions>
                    <Trigger.ExitActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.Y"
                                                 To="0" Duration="0:0:0.2"
                                                 EasingFunction="{StaticResource EaseOutQuad}" />
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.ExitActions>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 导航按钮 -->
        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Height" Value="46" />
            <Setter Property="Margin" Value="12,2,12,2" />
            <Setter Property="Padding" Value="16,0,16,0" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="NavBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="11"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Trigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <ColorAnimation Duration="0:0:0.15"
                                                Storyboard.TargetProperty="Background.Color"
                                                To="#8FFFFFFF"
                                                EasingFunction="{StaticResource EaseOutQuad}" />
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.EnterActions>
                    <Trigger.ExitActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <ColorAnimation Duration="0:0:0.15"
                                                Storyboard.TargetProperty="Background.Color"
                                                To="Transparent"
                                                EasingFunction="{StaticResource EaseOutQuad}" />
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.ExitActions>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="NavButtonActiveStyle" TargetType="Button" BasedOn="{StaticResource NavButtonStyle}">
            <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}" />
            <Setter Property="Background" Value="#B8FFFFFF" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <!-- TabControl 玻璃胶囊选项卡 -->
        <Style TargetType="TabControl">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="MinHeight" Value="36" />
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="Margin" Value="0,0,4,0" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="10,10,0,0">
                            <ContentPresenter ContentSource="Header" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="TabBorder"
                                                            Storyboard.TargetProperty="Background.Color"
                                                            To="#D9FFFFFF"
                                                            Duration="0:0:0.15"
                                                            EasingFunction="{StaticResource EaseOutQuad}" />
                                            <ColorAnimation Storyboard.TargetName="TabBorder"
                                                            Storyboard.TargetProperty="BorderBrush.Color"
                                                            To="#B8FFFFFF"
                                                            Duration="0:0:0.15"
                                                            EasingFunction="{StaticResource EaseOutQuad}" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="TabBorder"
                                                            Storyboard.TargetProperty="Background.Color"
                                                            To="Transparent"
                                                            Duration="0:0:0.15"
                                                            EasingFunction="{StaticResource EaseOutQuad}" />
                                            <ColorAnimation Storyboard.TargetName="TabBorder"
                                                            Storyboard.TargetProperty="BorderBrush.Color"
                                                            To="Transparent"
                                                            Duration="0:0:0.15"
                                                            EasingFunction="{StaticResource EaseOutQuad}" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                                <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}" />
                    <Setter Property="FontWeight" Value="SemiBold" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- TextBox -->
        <Style TargetType="TextBox">
            <Setter Property="MinHeight" Value="36" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="{DynamicResource BgCardBrush}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="9"
                                Padding="2,0">
                            <ScrollViewer Name="PART_ContentHost" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ComboBox -->
        <Style TargetType="ComboBox">
            <Setter Property="MinHeight" Value="36" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="#BFFFFFFF" />
            <Setter Property="FontSize" Value="13" />
        </Style>

        <!-- CheckBox -->
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="FontSize" Value="13" />
        </Style>

        <!-- ListBox -->
        <Style TargetType="ListBox">
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="#A6FFFFFF" />
            <Setter Property="Padding" Value="4" />
        </Style>

        <!-- Smooth ListBoxItem -->
        <Style TargetType="ListBoxItem">
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="9"
                                Padding="{TemplateBinding Padding}"
                                Name="ItemBorder">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource PrimaryLightBrush}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#A6FFFFFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ScrollViewer -->
        <Style TargetType="ScrollViewer">
            <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
            <Setter Property="HorizontalScrollBarVisibility" Value="Disabled" />
        </Style>

        <!-- 页面标题 -->
        <Style x:Key="PageTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="24" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="FontFamily" Value="Microsoft YaHei UI" />
        </Style>

        <Style x:Key="PageSubtitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
            <Setter Property="Margin" Value="0,4,0,0" />
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>

        <Style x:Key="FormLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>

        <!-- 状态徽章 -->
        <Style x:Key="StatusBadgeStyle" TargetType="Border">
            <Setter Property="Padding" Value="10,4" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Height" Value="24" />
        </Style>
    </Window.Resources>

    <!-- 主布局：左侧导航 + 右侧内容 -->
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="228" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- ===== 左侧导航栏 ===== -->
        <Border Grid.Column="0" Background="{DynamicResource GlassNavigationBrush}"
                BorderBrush="#8FFFFFFF" BorderThickness="0,0,1,0">
            <Grid>
                <!-- 原有导航内容 Grid -->
                <Grid>
                    <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Logo -->
                <StackPanel Grid.Row="0" Margin="24,28,24,32">
                    <StackPanel Orientation="Horizontal">
                        <Image Source="Resources/Images/logo_app.png"
                               Width="36" Height="36"
                               Margin="0,0,12,0" />
                        <TextBlock VerticalAlignment="Center"
                                   FontSize="16" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   Text="Click Assistant" />
                    </StackPanel>
                </StackPanel>

                <!-- 导航项 -->
                <StackPanel Grid.Row="1">
                    <Button x:Name="NavHomeButton"
                            Command="{Binding ShowHomeCommand}"
                            Content="首页">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource NavButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsHomePageVisible}" Value="True">
                                        <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}" />
                                        <Setter Property="Background" Value="{DynamicResource PrimaryLightBrush}" />
                                        <Setter Property="FontWeight" Value="SemiBold" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button x:Name="NavNewTaskButton"
                            Command="{Binding ShowNewTaskTypeCommand}"
                            Content="新建任务">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource NavButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsNewTaskTypePageVisible}" Value="True">
                                        <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}" />
                                        <Setter Property="Background" Value="{DynamicResource PrimaryLightBrush}" />
                                        <Setter Property="FontWeight" Value="SemiBold" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button x:Name="NavTaskLibraryButton"
                            Command="{Binding ShowTaskLibraryCommand}"
                            Content="任务库">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource NavButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsTaskLibraryPageVisible}" Value="True">
                                        <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}" />
                                        <Setter Property="Background" Value="{DynamicResource PrimaryLightBrush}" />
                                        <Setter Property="FontWeight" Value="SemiBold" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button x:Name="NavLogsButton"
                            Command="{Binding ShowExecutionLogsCommand}"
                            Content="执行日志">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource NavButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsExecutionLogsPageVisible}" Value="True">
                                        <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}" />
                                        <Setter Property="Background" Value="{DynamicResource PrimaryLightBrush}" />
                                        <Setter Property="FontWeight" Value="SemiBold" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>

                <!-- 底部状态 -->
                <Border Grid.Row="3" Margin="16,0,16,20" Padding="14"
                        Background="#F9FAFB" CornerRadius="10"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock FontSize="12" Foreground="{DynamicResource TextMutedBrush}"
                                   Text="执行状态" />
                        <TextBlock FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource PrimaryBrush}"
                                   Text="{Binding StatusText}" Margin="0,2,0,0" />
                        <TextBlock FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"
                                   Text="{Binding HotkeyStatus}" Margin="0,6,0,0"
                                   TextTrimming="CharacterEllipsis" />
                        <TextBlock FontSize="10" Foreground="{DynamicResource TextMutedBrush}"
                                   Text="{Binding VersionText}" Margin="0,8,0,0" />
                        <Button x:Name="ThemeToggleButton"
                                Content="🌙 深色模式"
                                FontSize="11"
                                Margin="0,8,0,0"
                                Padding="8,4"
                                Background="Transparent"
                                BorderThickness="0"
                                Cursor="Hand"
                                Click="HandleThemeToggleClick" />
                    </StackPanel>
                </Border>
                </Grid>
                <!-- 品牌蓝氛围光：底部渐变，模拟环境光在天蓝玻璃上的折射 -->
                <Border VerticalAlignment="Bottom" Height="120"
                        IsHitTestVisible="False">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Offset="0" Color="Transparent" />
                            <GradientStop Offset="1" Color="#183978F6" />
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>
            </Grid>
        </Border>

        <!-- ===== 右侧内容区域 ===== -->
        <ScrollViewer x:Name="ContentScrollViewer" Grid.Column="1" Padding="28,24,28,28">
            <Grid>
                <!-- ********** 首页 ********** -->
                <Grid x:Name="HomePageGrid"
                      Visibility="{Binding IsHomePageVisible, Converter={StaticResource BoolToVisibility}}">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="560">
                        <!-- Hero 区域 -->
                        <local:GlassCard Margin="0,0,0,20" Style="{StaticResource CardStyle}" Padding="28">
                            <StackPanel HorizontalAlignment="Center">
                                <Image Source="Resources/Images/logo_app.png"
                                       Width="56" Height="56"
                                       Margin="0,0,0,16" />
                                <TextBlock HorizontalAlignment="Center"
                                           FontSize="28" FontWeight="Bold"
                                           Text="Click Assistant" />
                                <TextBlock HorizontalAlignment="Center"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           Text="点击与输入助手 — 自动化重复操作" Margin="0,6,0,0" />
                                <WrapPanel HorizontalAlignment="Center" Margin="0,14,0,0">
                                    <Button Command="{Binding ShowNewTaskTypeCommand}" Content="新建任务"
                                            Style="{StaticResource PrimaryButtonStyle}" />
                                    <Button Command="{Binding ShowTaskLibraryCommand}" Content="任务库"
                                            Style="{StaticResource SecondaryButtonStyle}" />
                                    <Button Command="{Binding ShowExecutionLogsCommand}" Content="执行日志"
                                            Style="{StaticResource SecondaryButtonStyle}" />
                                </WrapPanel>
                            </StackPanel>
                        </local:GlassCard>

                        <!-- 最近任务 -->
                        <TextBlock FontSize="18" FontWeight="Bold" Margin="0,8,0,12"
                                   Text="最近任务" Foreground="{DynamicResource TextPrimaryBrush}" />
                        <ItemsControl ItemsSource="{Binding RecentTasks}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,8" Style="{StaticResource SubtleCardStyle}" Padding="12,10">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Width="36" Height="36"
                                                    Background="{DynamicResource PrimaryLightBrush}"
                                                    CornerRadius="8" Margin="0,0,10,0">
                                                <Image Source="Resources/Images/icon_tap.png" Width="20" Height="20" />
                                            </Border>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock FontWeight="SemiBold" FontSize="14"
                                                           Text="{Binding Name}" />
                                                <TextBlock FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"
                                                           Text="{Binding Description, StringFormat={}{0}}" />
                                            </StackPanel>
                                            <Button Grid.Column="2" Content="执行"
                                                    Style="{StaticResource PrimaryButtonStyle}"
                                                    MinHeight="30" Padding="12,4"
                                                    Command="{Binding DataContext.StartCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- 执行状态 -->
                        <Border Margin="0,12,0,0" Style="{StaticResource SubtleCardStyle}">
                            <StackPanel>
                                <TextBlock FontSize="14" FontWeight="SemiBold" Text="执行状态" />
                                <TextBlock Margin="0,6,0,0" FontSize="13"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           Text="{Binding ExecutionSafetyText}" />
                                <TextBlock Margin="0,4,0,0" FontSize="12"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           Text="{Binding HotkeyStatus}" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>

                <!-- ********** 新建任务类型选择 ********** -->
                <Grid x:Name="NewTaskTypeGrid"
                      Visibility="{Binding IsNewTaskTypePageVisible, Converter={StaticResource BoolToVisibility}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="20" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0">
                        <TextBlock Style="{StaticResource PageTitleStyle}" Text="新建任务" />
                        <TextBlock Style="{StaticResource PageSubtitleStyle}" Text="选择任务类型开始创建自动化任务。" />
                    </StackPanel>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="14" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="14" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- 鼠标点击 -->
                        <Button Grid.Row="0" Grid.Column="0"
                                Command="{Binding CreateMouseClickTaskCommand}"
                                Style="{StaticResource ChoiceButtonStyle}">
                            <StackPanel>
                                <Border Width="48" Height="48"
                                        Background="{DynamicResource PrimaryLightBrush}"
                                        CornerRadius="10" Margin="0,0,0,12">
                                    <Image Source="Resources/Images/icon_tap.png" Width="28" Height="28" />
                                </Border>
                                <TextBlock FontSize="18" FontWeight="SemiBold" Text="鼠标点击" />
                                <TextBlock Margin="0,8,0,0" Foreground="{DynamicResource TextSecondaryBrush}"
                                           Text="固定坐标点击、重复点击、开始延迟和点击间隔。支持多位置顺序执行。" />
                                <TextBlock Margin="0,14,0,0" FontWeight="SemiBold"
                                           Foreground="{StaticResource PrimaryBrush}"
                                           Text="进入鼠标点击编辑页" />
                            </StackPanel>
                        </Button>

                        <!-- 键盘按键 -->
                        <Button Grid.Row="0" Grid.Column="2"
                                Command="{Binding CreateKeyboardTaskCommand}"
                                Style="{StaticResource ChoiceButtonStyle}">
                            <StackPanel>
                                <Border Width="48" Height="48"
                                        Background="{DynamicResource WarningLightBrush}"
                                        CornerRadius="10" Margin="0,0,0,12">
                                    <Image Source="Resources/Images/icon_keyboard.png" Width="28" Height="28" />
                                </Border>
                                <TextBlock FontSize="18" FontWeight="SemiBold" Text="键盘按键" />
                                <TextBlock Margin="0,8,0,0" Foreground="{DynamicResource TextSecondaryBrush}"
                                           Text="单键或连续按键任务，适合重复触发快捷操作。支持按键捕获。" />
                                <TextBlock Margin="0,14,0,0" FontWeight="SemiBold"
                                           Foreground="{StaticResource WarningBrush}"
                                           Text="先保存到任务库" />
                            </StackPanel>
                        </Button>

                        <!-- 文本输入 -->
                        <Button Grid.Row="2" Grid.Column="0"
                                Command="{Binding CreateTextInputTaskCommand}"
                                Style="{StaticResource ChoiceButtonStyle}">
                            <StackPanel>
                                <Border Width="48" Height="48"
                                        Background="{DynamicResource SecondaryLightBrush}"
                                        CornerRadius="10" Margin="0,0,0,12">
                                    <Image Source="Resources/Images/icon_text_input.png" Width="28" Height="28" />
                                </Border>
                                <TextBlock FontSize="18" FontWeight="SemiBold" Text="文本输入" />
                                <TextBlock Margin="0,8,0,0" Foreground="{DynamicResource TextSecondaryBrush}"
                                           Text="保存常用文本并可配置字符间隔自动输入。支持自动聚焦目标输入框。" />
                                <TextBlock Margin="0,14,0,0" FontWeight="SemiBold"
                                           Foreground="{StaticResource SecondaryBrush}"
                                           Text="先保存到任务库" />
                            </StackPanel>
                        </Button>

                        <!-- 组合任务 -->
                        <Button Grid.Row="2" Grid.Column="2"
                                Command="{Binding CreateComboTaskCommand}"
                                Style="{StaticResource ChoiceButtonStyle}">
                            <StackPanel>
                                <Border Width="48" Height="48"
                                        Background="{DynamicResource CyanLightBrush}"
                                        CornerRadius="10" Margin="0,0,0,12">
                                    <Image Source="Resources/Images/icon_combo.png" Width="28" Height="28" />
                                </Border>
                                <TextBlock FontSize="18" FontWeight="SemiBold" Text="组合任务" />
                                <TextBlock Margin="0,8,0,0" Foreground="{DynamicResource TextSecondaryBrush}"
                                           Text="把鼠标、按键和文本组合成一组执行流程，按顺序自动执行。" />
                                <TextBlock Margin="0,14,0,0" FontWeight="SemiBold"
                                           Foreground="{StaticResource CyanBrush}"
                                           Text="先保存到任务库" />
                            </StackPanel>
                        </Button>

                        <!-- 滑动任务 -->
                        <Button Grid.Row="2" Grid.Column="0"
                                Style="{StaticResource ChoiceButtonStyle}">
                            <StackPanel>
                                <Border Width="48" Height="48"
                                        Background="{DynamicResource SuccessLightBrush}"
                                        CornerRadius="10" Margin="0,0,0,12">
                                    <Image Source="Resources/Images/icon_swipe.png" Width="28" Height="28" />
                                </Border>
                                <TextBlock FontSize="18" FontWeight="SemiBold" Text="滑动手势" />
                                <TextBlock Margin="0,8,0,0" Foreground="{DynamicResource TextSecondaryBrush}"
                                           Text="配置屏幕滑动轨迹，适合触控设备或模拟滑动操作。" />
                            </StackPanel>
                        </Button>
                    </Grid>
                </Grid>

                <!-- ********** 任务库页 ********** -->
                <Grid x:Name="TaskLibraryGrid"
                      Visibility="{Binding IsTaskLibraryPageVisible, Converter={StaticResource BoolToVisibility}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="16" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0">
                        <TextBlock Style="{StaticResource PageTitleStyle}" Text="任务库" />
                        <TextBlock Style="{StaticResource PageSubtitleStyle}" Text="管理已保存的任务，编辑步骤后可直接执行。" />
                    </StackPanel>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="340" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- 左栏：任务列表 -->
                        <local:GlassCard Grid.Column="0" Style="{StaticResource CardStyle}">
                            <DockPanel LastChildFill="True">
                                <StackPanel DockPanel.Dock="Top" Margin="0,0,0,14">
                                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="已保存任务" />
                                    <Button Margin="0,10,0,0"
                                            Command="{Binding ShowNewTaskTypeCommand}"
                                            Content="新建任务"
                                            Style="{StaticResource PrimaryButtonStyle}" />
                                    <Button Margin="0,8,0,0"
                                            Command="{Binding StartCommand}"
                                            Content="▶ 快捷执行"
                                            Style="{StaticResource SecondaryButtonStyle}" />
                                    <Button Margin="0,8,0,0"
                                            Command="{Binding DuplicateTaskCommand}"
                                            Content="复制选中任务"
                                            Style="{StaticResource SecondaryButtonStyle}" />
                                    <Button Margin="0,8,0,0"
                                            Command="{Binding DeleteTaskCommand}"
                                            Content="删除选中任务"
                                            Style="{StaticResource DangerButtonStyle}" />
                                </StackPanel>
                                <ListBox MinHeight="400"
                                         ItemsSource="{Binding Tasks}"
                                         SelectedItem="{Binding SelectedTask, Mode=TwoWay}">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="4">
                                                <TextBlock FontWeight="SemiBold" FontSize="14"
                                                           Text="{Binding Name}" />
                                                <TextBlock Margin="0,4,0,0" FontSize="12"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                           TextTrimming="CharacterEllipsis"
                                                           Text="{Binding Description}" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </DockPanel>
                        </local:GlassCard>

                        <!-- 右栏：任务详情 -->
                        <local:GlassCard Grid.Column="2" Style="{StaticResource CardStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="12" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="10" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0">
                                    <TextBlock FontSize="20" FontWeight="Bold"
                                               Text="{Binding SelectedTask.Name}" />
                                    <TextBlock Margin="0,4,0,0" FontSize="13"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               Text="{Binding SelectedTaskMetaText}" />
                                </StackPanel>

                                <TabControl Grid.Row="2" SelectedIndex="{Binding TaskLibrarySelectedTabIndex, Mode=TwoWay}">
                                    <!-- 基础信息 Tab -->
                                    <TabItem Header="基础信息">
                                        <Border Margin="0,14,0,0" Style="{StaticResource SubtleCardStyle}">
                                            <Grid IsEnabled="{Binding IsTaskEditorEnabled}">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="16" />
                                                    <ColumnDefinition Width="140" />
                                                    <ColumnDefinition Width="16" />
                                                    <ColumnDefinition Width="150" />
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>

                                                <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource FormLabelStyle}" Text="任务名称" />
                                                <TextBlock Grid.Row="0" Grid.Column="2" Style="{StaticResource FormLabelStyle}" Text="重复次数" />
                                                <TextBlock Grid.Row="0" Grid.Column="4" Style="{StaticResource FormLabelStyle}" Text="开始延迟（毫秒）" />

                                                <TextBox Grid.Row="1" Grid.Column="0" Margin="0,4,0,0"
                                                         Text="{Binding SelectedTask.Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                <TextBox Grid.Row="1" Grid.Column="2" Margin="0,4,0,0"
                                                         Text="{Binding SelectedTask.RepeatCount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                <TextBox Grid.Row="1" Grid.Column="4" Margin="0,4,0,0"
                                                         Text="{Binding SelectedTask.StartDelayMs, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                <TextBlock Grid.Row="2" Grid.Column="4" Margin="0,4,0,8" FontSize="11"
                                                           Foreground="{DynamicResource TextMutedBrush}"
                                                           Text="点开始后，等待多久再执行第一步。" />

                                                <TextBlock Grid.Row="3" Grid.Column="0" Style="{StaticResource FormLabelStyle}" Text="任务说明" />
                                                <TextBox Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="5" Margin="0,4,0,0"
                                                         MinHeight="64" AcceptsReturn="True"
                                                         TextWrapping="Wrap"
                                                         Text="{Binding SelectedTask.Description, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                            </Grid>
                                        </Border>
                                    </TabItem>

                                    <!-- 步骤设置 Tab -->
                                    <TabItem Header="步骤设置">
                                        <Border Margin="0,14,0,0" Style="{StaticResource SubtleCardStyle}">
                                            <Grid IsEnabled="{Binding IsTaskEditorEnabled}">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="240" />
                                                    <ColumnDefinition Width="16" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="10" />
                                                    <RowDefinition Height="*" />
                                                </Grid.RowDefinitions>

                                                <DockPanel Grid.Row="0" Grid.ColumnSpan="3">
                                                    <Button DockPanel.Dock="Right" Content="＋ 添加步骤"
                                                            Style="{StaticResource PrimaryButtonStyle}"
                                                            MinHeight="34" Padding="14,6">
                                                        <Button.ContextMenu>
                                                            <ContextMenu>
                                                                <MenuItem Header="鼠标点击" Command="{Binding AddStepCommand}" />
                                                                <MenuItem Header="键盘按键" Command="{Binding AddKeyboardStepCommand}" />
                                                                <MenuItem Header="组合键" Command="{Binding AddShortcutStepCommand}" />
                                                                <MenuItem Header="文本输入" Command="{Binding AddTextInputStepCommand}" />
                                                            </ContextMenu>
                                                        </Button.ContextMenu>
                                                    </Button>
                                                    <StackPanel>
                                                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="步骤配置" />
                                                        <TextBlock FontSize="12"
                                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                                   Text="已保存任务可在这里直接编辑步骤，保存后生效。" />
                                                    </StackPanel>
                                                </DockPanel>

                                                <ListBox x:Name="StepListBox"
                                                         Grid.Row="2" Grid.Column="0"
                                                         MinHeight="220"
                                                         ItemsSource="{Binding CurrentSteps}"
                                                         SelectedItem="{Binding SelectedStep, Mode=TwoWay}">
                                                    <ListBox.ItemContainerStyle>
                                                        <Style TargetType="ListBoxItem">
                                                            <Setter Property="AllowDrop" Value="True" />
                                                            <Setter Property="Padding" Value="6" />
                                                            <Style.Triggers>
                                                                <Trigger Property="IsSelected" Value="True">
                                                                    <Trigger.EnterActions>
                                                                        <BeginStoryboard>
                                                                            <Storyboard>
                                                                                <ColorAnimation Storyboard.TargetProperty="Background.Color"
                                                                                                To="#DDEAFF"
                                                                                                Duration="0:0:0.15"
                                                                                                EasingFunction="{StaticResource EaseOutQuad}" />
                                                                            </Storyboard>
                                                                        </BeginStoryboard>
                                                                    </Trigger.EnterActions>
                                                                    <Trigger.ExitActions>
                                                                        <BeginStoryboard>
                                                                            <Storyboard>
                                                                                <ColorAnimation Storyboard.TargetProperty="Background.Color"
                                                                                                To="Transparent"
                                                                                                Duration="0:0:0.2"
                                                                                                EasingFunction="{StaticResource EaseOutQuad}" />
                                                                            </Storyboard>
                                                                        </BeginStoryboard>
                                                                    </Trigger.ExitActions>
                                                                </Trigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </ListBox.ItemContainerStyle>
                                                    <ListBox.ItemTemplate>
                                                        <DataTemplate>
                                                            <StackPanel Margin="2">
                                                                <StackPanel Orientation="Horizontal">
                                                                    <TextBlock FontWeight="Bold" FontSize="13"
                                                                               Foreground="{StaticResource PrimaryBrush}"
                                                                               Text="{Binding Order, StringFormat='{}{0}'}">
                                                                        <TextBlock.Style>
                                                                            <Style TargetType="TextBlock">
                                                                                <Setter Property="Width" Value="22" />
                                                                            </Style>
                                                                        </TextBlock.Style>
                                                                    </TextBlock>
                                                                    <TextBlock Margin="4,0,0,0" FontSize="14"
                                                                               FontWeight="SemiBold"
                                                                               Text="{Binding Name}" />
                                                                </StackPanel>
                                                                <TextBlock Margin="8,2,0,0" FontSize="11"
                                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                                           Text="{Binding Converter={StaticResource StepSummaryConverter}}" />
                                                            </StackPanel>
                                                        </DataTemplate>
                                                    </ListBox.ItemTemplate>
                                                </ListBox>

                                                <!-- 步骤详细编辑区 -->
                                                <Grid Grid.Row="2" Grid.Column="2">
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="10" />
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="10" />
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="10" />
                                                        <RowDefinition Height="Auto" />
                                                    </Grid.RowDefinitions>

                                                    <!-- 基本属性 -->
                                                    <Grid Grid.Row="0">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="12" />
                                                            <ColumnDefinition Width="150" />
                                                            <ColumnDefinition Width="12" />
                                                            <ColumnDefinition Width="100" />
                                                        </Grid.ColumnDefinitions>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="Auto" />
                                                        </Grid.RowDefinitions>
                                                        <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource FormLabelStyle}" Text="步骤名称" />
                                                        <TextBlock Grid.Row="0" Grid.Column="2" Style="{StaticResource FormLabelStyle}" Text="动作类型" />
                                                        <TextBlock Grid.Row="0" Grid.Column="4" Style="{StaticResource FormLabelStyle}" Text="启用" />
                                                        <TextBox Grid.Row="1" Grid.Column="0" Margin="0,4,0,0"
                                                                 Text="{Binding SelectedStepName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                        <ComboBox Grid.Row="1" Grid.Column="2" Margin="0,4,0,0"
                                                                  ItemsSource="{Binding InputActionTypeOptions}"
                                                                  DisplayMemberPath="DisplayName"
                                                                  SelectedValuePath="Value"
                                                                  SelectedValue="{Binding SelectedStepActionType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                        <CheckBox Grid.Row="1" Grid.Column="4" Margin="0,10,0,0"
                                                                  IsChecked="{Binding SelectedStepEnabled, Mode=TwoWay}" />
                                                    </Grid>

                                                    <!-- 步骤前等待 -->
                                                    <Grid Grid.Row="2">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="150" />
                                                            <ColumnDefinition Width="12" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="Auto" />
                                                        </Grid.RowDefinitions>
                                                        <TextBlock Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Style="{StaticResource FormLabelStyle}" Text="步骤前等待（毫秒）" />
                                                        <TextBox Grid.Row="1" Grid.Column="0" Margin="0,4,0,0"
                                                                 Text="{Binding SelectedStepBeforeDelayMs, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                        <TextBlock Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,2,0,0" FontSize="11"
                                                                   Foreground="{DynamicResource TextMutedBrush}"
                                                                   Text="步骤间等待由下一步骤的前等待控制。" />
                                                    </Grid>

                                                    <!-- 鼠标点击字段 -->
                                                    <Grid Grid.Row="4" Visibility="{Binding IsMouseStepFieldsVisible, Converter={StaticResource BoolToVisibility}}">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="90" />
                                                            <ColumnDefinition Width="10" />
                                                            <ColumnDefinition Width="90" />
                                                            <ColumnDefinition Width="10" />
                                                            <ColumnDefinition Width="100" />
                                                            <ColumnDefinition Width="10" />
                                                            <ColumnDefinition Width="90" />
                                                            <ColumnDefinition Width="10" />
                                                            <ColumnDefinition Width="90" />
                                                        </Grid.ColumnDefinitions>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="8" />
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="Auto" />
                                                        </Grid.RowDefinitions>
                                                        <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource FormLabelStyle}" Text="X 坐标" />
                                                        <TextBlock Grid.Row="0" Grid.Column="2" Style="{StaticResource FormLabelStyle}" Text="Y 坐标" />
                                                        <TextBlock Grid.Row="0" Grid.Column="4" Style="{StaticResource FormLabelStyle}" Text="点击次数" />
                                                        <TextBlock Grid.Row="0" Grid.Column="6" Style="{StaticResource FormLabelStyle}" Text="连点间隔ms" />
                                                        <TextBlock Grid.Row="0" Grid.Column="8" Style="{StaticResource FormLabelStyle}" Text="按压时长ms" />
                                                        <TextBox Grid.Row="1" Grid.Column="0" Margin="0,4,0,0"
                                                                 Text="{Binding SelectedStepX, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                        <TextBox Grid.Row="1" Grid.Column="2" Margin="0,4,0,0"
                                                                 Text="{Binding SelectedStepY, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                        <TextBox Grid.Row="1" Grid.Column="4" Margin="0,4,0,0"
                                                                 Text="{Binding SelectedStepMouseClickCount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                        <TextBox Grid.Row="1" Grid.Column="6" Margin="0,4,0,0"
                                                                 Text="{Binding SelectedStepClickIntervalMs, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                        <TextBox Grid.Row="1" Grid.Column="8" Margin="0,4,0,0"
                                                                 Text="{Binding SelectedStepPressDurationMs, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                        <TextBlock Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="4" Style="{StaticResource FormLabelStyle}" Text="点击方式" />
                                                        <ComboBox Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="4" Margin="0,4,0,0"
                                                                  ItemsSource="{Binding ClickTypeOptions}"
                                                                  DisplayMemberPath="DisplayName"
                                                                  SelectedValuePath="Value"
                                                                  SelectedValue="{Binding SelectedStepClickType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                        <WrapPanel Grid.Row="4" Grid.Column="4" Grid.ColumnSpan="5" Margin="8,4,0,0">
                                                            <Button Command="{Binding CaptureCoordinateCommand}" Content="选择坐标"
                                                                    Style="{StaticResource SecondaryButtonStyle}" />
                                                            <Button Command="{Binding TestMouseClickCommand}" Content="测试点击"
                                                                    Style="{StaticResource SecondaryButtonStyle}" />
                                                        </WrapPanel>
                                                    </Grid>

                                                    <!-- 滑动字段 -->
                                                    <Grid Grid.Row="4" Visibility="{Binding IsSwipeStepFieldsVisible, Converter={StaticResource BoolToVisibility}}">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="90" />
                                                            <ColumnDefinition Width="10" />
                                                            <ColumnDefinition Width="90" />
                                                            <ColumnDefinition Width="10" />
                                                            <ColumnDefinition Width="90" />
                                                            <ColumnDefinition Width="10" />
                                                            <ColumnDefinition Width="90" />
                                                            <ColumnDefinition Width="10" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="8" />
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="Auto" />
                                                        </Grid.RowDefinitions>
                                                        <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource FormLabelStyle}" Text="起点 X" />
                                                        <TextBlock Grid.Row="0" Grid.Column="2" Style="{StaticResource FormLabelStyle}" Text="起点 Y" />
                                                        <TextBlock Grid.Row="0" Grid.Column="4" Style="{StaticResource FormLabelStyle}" Text="终点 X" />
                                                        <TextBlock Grid.Row="0" Grid.Column="6" Style="{StaticResource FormLabelStyle}" Text="终点 Y" />
                                                        <TextBox Grid.Row="1" Grid.Column="0" Margin="0,4,0,0"
                                                                 Text="{Binding SelectedStepX, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                        <TextBox Grid.Row="1" Grid.Column="2" Margin="0,4,0,0"
                                                                 Text="{Binding SelectedStepY, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                        <TextBox Grid.Row="1" Grid.Column="4" Margin="0,4,0,0"
                                                                 Text="{Binding SelectedStepEndX, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                        <TextBox Grid.Row="1" Grid.Column="6" Margin="0,4,0,0"
                                                                 Text="{Binding SelectedStepEndY, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                        <TextBlock Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" Style="{StaticResource FormLabelStyle}" Text="滑动时长(ms)" />
                                                        <TextBox Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,4,0,0"
                                                                 Text="{Binding SelectedStepSwipeDurationMs, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                        <Button Grid.Row="4" Grid.Column="4" Grid.ColumnSpan="5" Margin="8,4,0,0"
                                                                Command="{Binding CaptureCoordinateCommand}" Content="选择坐标"
                                                                Style="{StaticResource SecondaryButtonStyle}" />
                                                    </Grid>

                                                    <!-- 键盘按键字段 -->
                                                    <Grid Grid.Row="4" Visibility="{Binding IsKeyboardStepFieldsVisible, Converter={StaticResource BoolToVisibility}}">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="12" />
                                                            <ColumnDefinition Width="130" />
                                                            <ColumnDefinition Width="12" />
                                                            <ColumnDefinition Width="140" />
                                                        </Grid.ColumnDefinitions>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="Auto" />
                                                        </Grid.RowDefinitions>
                                                        <Border Grid.Row="0" Grid.RowSpan="2" Grid.Column="0"
                                                                Padding="14" CornerRadius="8"
                                                                Background="{DynamicResource PrimaryLightBrush}"
                                                                BorderBrush="#93C5FD" BorderThickness="1">
                                                            <StackPanel>
                                                                <TextBlock FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" Text="按键捕获" />
                                                                <TextBlock Margin="0,8,0,0" FontSize="20" FontWeight="Bold"
                                                                           Foreground="{StaticResource PrimaryDarkBrush}"
                                                                           Text="{Binding SelectedStepKeyDisplayText}" />
                                                                <TextBox x:Name="KeyboardCaptureTextBox" Margin="0,10,0,0"
                                                                         Cursor="Hand" Focusable="True"
                                                                         GotKeyboardFocus="HandleKeyboardCaptureGotKeyboardFocus"
                                                                         IsReadOnly="True"
                                                                         LostKeyboardFocus="HandleKeyboardCaptureLostKeyboardFocus"
                                                                         PreviewKeyDown="HandleKeyboardCapturePreviewKeyDown"
                                                                         PreviewMouseLeftButtonDown="HandleKeyboardCapturePreviewMouseLeftButtonDown"
                                                                         Text="{Binding SelectedStepKeyName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                                <TextBlock Margin="0,6,0,0" FontSize="11"
                                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                                           Text="{Binding KeyboardCaptureStatus}" />
                                                            </StackPanel>
                                                        </Border>
                                                        <TextBlock Grid.Row="0" Grid.Column="2" Style="{StaticResource FormLabelStyle}" Text="连按次数" />
                                                        <TextBlock Grid.Row="0" Grid.Column="4" Style="{StaticResource FormLabelStyle}" Text="连按间隔（毫秒）" />
                                                        <TextBox Grid.Row="1" Grid.Column="2" Margin="0,4,0,0"
                                                                 Text="{Binding SelectedStepKeyPressCount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                        <TextBox Grid.Row="1" Grid.Column="4" Margin="0,4,0,0"
                                                                 Text="{Binding SelectedStepKeyIntervalMs, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                    </Grid>

                                                    <!-- 组合键字段 -->
                                                    <Grid Grid.Row="4" Visibility="{Binding IsShortcutStepFieldsVisible, Converter={StaticResource BoolToVisibility}}">
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="Auto" />
                                                        </Grid.RowDefinitions>
                                                        <TextBlock Style="{StaticResource FormLabelStyle}" Text="组合键（如 Ctrl+C）" />
                                                        <TextBox Grid.Row="1" Margin="0,4,0,0"
                                                                 Text="{Binding SelectedStepShortcutKeys, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                    </Grid>

                                                    <!-- 文本输入字段 -->
                                                    <Grid Grid.Row="4" Visibility="{Binding IsTextInputStepFieldsVisible, Converter={StaticResource BoolToVisibility}}">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="12" />
                                                            <ColumnDefinition Width="140" />
                                                        </Grid.ColumnDefinitions>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="Auto" />
                                                        </Grid.RowDefinitions>
                                                        <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource FormLabelStyle}" Text="文本内容" />
                                                        <TextBlock Grid.Row="0" Grid.Column="2" Style="{StaticResource FormLabelStyle}" Text="字符间隔（毫秒）" />
                                                        <TextBox Grid.Row="1" Grid.Column="0" Margin="0,4,0,0"
                                                                 MinHeight="72" AcceptsReturn="True" TextWrapping="Wrap"
                                                                 Text="{Binding SelectedStepTextContent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                        <TextBox Grid.Row="1" Grid.Column="2" Margin="0,4,0,0"
                                                                 Text="{Binding SelectedStepKeyIntervalMs, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                        <CheckBox Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,6,0,0"
                                                                  Content="输入前自动点击目标位置获得焦点"
                                                                  IsChecked="{Binding SelectedStepAutoFocusBeforeInput, Mode=TwoWay}" />
                                                    </Grid>

                                                    <Button Grid.Row="6" Command="{Binding RemoveStepCommand}"
                                                            Content="删除当前步骤" Style="{StaticResource DangerButtonStyle}" />
                                                </Grid>
                                            </Grid>
                                        </Border>
                                    </TabItem>
                                </TabControl>

                                <!-- 执行操作栏（底部固定） -->
                                <Border Grid.Row="4" Style="{StaticResource SubtleCardStyle}">
                                    <WrapPanel>
                                        <TextBlock VerticalAlignment="Center" FontSize="12"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   Text="{Binding ExecutionSummary}"
                                                   MaxWidth="400" TextTrimming="CharacterEllipsis"
                                                   Margin="0,0,12,0" />
                                        <Button Command="{Binding SaveTaskCommand}" Content="保存"
                                                Style="{StaticResource SecondaryButtonStyle}" />
                                        <Button Command="{Binding StartCommand}" Content="执行"
                                                Style="{StaticResource PrimaryButtonStyle}" />
                                        <Button Command="{Binding DuplicateTaskCommand}" Content="复制"
                                                Style="{StaticResource SecondaryButtonStyle}" />
                                        <Button Command="{Binding DeleteTaskCommand}" Content="删除"
                                                Style="{StaticResource DangerButtonStyle}" />
                                    </WrapPanel>
                                </Border>
                            </Grid>
                        </local:GlassCard>
                    </Grid>
                </Grid>

                <!-- ********** 执行日志页 ********** -->
                <Grid x:Name="LogsGrid"
                      Visibility="{Binding IsExecutionLogsPageVisible, Converter={StaticResource BoolToVisibility}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="16" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0">
                        <TextBlock Style="{StaticResource PageTitleStyle}" Text="执行日志" />
                        <TextBlock Style="{StaticResource PageSubtitleStyle}" Text="历史执行记录和当前任务运行日志。" />
                    </StackPanel>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <local:GlassCard Grid.Column="0" Style="{StaticResource CardStyle}">
                            <DockPanel LastChildFill="True">
                                <TextBlock DockPanel.Dock="Top" Margin="0,0,0,12"
                                           Style="{StaticResource SectionTitleStyle}" Text="历史执行记录" />
                                <ListBox MinHeight="440" ItemsSource="{Binding RecentLogs}" />
                            </DockPanel>
                        </local:GlassCard>
                        <local:GlassCard Grid.Column="2" Style="{StaticResource CardStyle}">
                            <DockPanel LastChildFill="True">
                                <TextBlock DockPanel.Dock="Top" Margin="0,0,0,12"
                                           Style="{StaticResource SectionTitleStyle}" Text="当前任务运行日志" />
                                <ListBox MinHeight="440" ItemsSource="{Binding RuntimeLogs}" />
                            </DockPanel>
                        </local:GlassCard>
                    </Grid>
                </Grid>

                <!-- ********** 鼠标点击任务编辑页 ********** -->
                <Grid Visibility="{Binding IsMouseClickEditorPageVisible, Converter={StaticResource BoolToVisibility}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="16" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="16" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0">
                        <TextBlock Style="{StaticResource PageTitleStyle}" Text="鼠标点击任务编辑" />
                        <TextBlock FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,0"
                                   Text="配置固定坐标、点击次数、开始延迟和点击间隔。运行中请用悬浮窗暂停或停止。" />
                    </StackPanel>

                    <local:GlassCard Grid.Row="2" Style="{StaticResource CardStyle}">
                        <Grid IsEnabled="{Binding IsTaskEditorEnabled}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="280" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="250" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Style="{StaticResource SectionTitleStyle}" Text="点击位置（按顺序执行）" />
                                <TextBlock FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                                           TextWrapping="Wrap" Text="{Binding MousePositionSummary}" />
                                <ListBox x:Name="MouseStepListBox" Margin="0,10,0,0" MinHeight="220"
                                         ItemsSource="{Binding MouseSteps}"
                                         SelectedItem="{Binding SelectedStep, Mode=TwoWay}">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="4">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}"
                                                               Text="{Binding Order, StringFormat='{}{0}'}" />
                                                    <TextBlock Margin="6,0,0,0" FontWeight="SemiBold"
                                                               Text="{Binding Name}" />
                                                </StackPanel>
                                                <TextBlock Margin="0,4,0,0" FontSize="11"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                           Text="{Binding Converter={StaticResource StepSummaryConverter}}" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                                <WrapPanel Margin="0,10,0,0">
                                    <Button Command="{Binding AddStepCommand}" Content="添加位置"
                                            Style="{StaticResource PrimaryButtonStyle}" />
                                    <Button Command="{Binding RemoveStepCommand}" Content="删除位置"
                                            Style="{StaticResource DangerButtonStyle}" />
                                </WrapPanel>
                            </StackPanel>

                            <Grid Grid.Column="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="14" />
                                    <ColumnDefinition Width="140" />
                                    <ColumnDefinition Width="14" />
                                    <ColumnDefinition Width="150" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="10" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="14" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="14" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource FormLabelStyle}" Text="任务名称" />
                                <TextBlock Grid.Row="0" Grid.Column="2" Style="{StaticResource FormLabelStyle}" Text="执行轮数" />
                                <TextBlock Grid.Row="0" Grid.Column="4" Style="{StaticResource FormLabelStyle}" Text="开始延迟（毫秒）" />
                                <TextBox Grid.Row="1" Grid.Column="0" Margin="0,4,0,0"
                                         Text="{Binding MouseTaskName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBox Grid.Row="1" Grid.Column="2" Margin="0,4,0,0"
                                         Text="{Binding MouseRepeatCount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBox Grid.Row="1" Grid.Column="4" Margin="0,4,0,0"
                                         Text="{Binding MouseStartDelayMs, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Grid.Row="3" Grid.Column="0" Style="{StaticResource FormLabelStyle}" Text="任务说明" />
                                <TextBox Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="5" Margin="0,4,0,0"
                                         MinHeight="56" AcceptsReturn="True" TextWrapping="Wrap"
                                         Text="{Binding MouseTaskDescription, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Grid.Row="6" Grid.ColumnSpan="5" FontSize="15" FontWeight="SemiBold"
                                           Text="当前选中位置" />
                                <Grid Grid.Row="7" Grid.ColumnSpan="5" Margin="0,6,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="10" />
                                        <ColumnDefinition Width="100" />
                                        <ColumnDefinition Width="10" />
                                        <ColumnDefinition Width="100" />
                                        <ColumnDefinition Width="10" />
                                        <ColumnDefinition Width="110" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="10" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource FormLabelStyle}" Text="位置名称" />
                                    <TextBlock Grid.Row="0" Grid.Column="2" Style="{StaticResource FormLabelStyle}" Text="X 坐标" />
                                    <TextBlock Grid.Row="0" Grid.Column="4" Style="{StaticResource FormLabelStyle}" Text="Y 坐标" />
                                    <TextBlock Grid.Row="0" Grid.Column="6" Style="{StaticResource FormLabelStyle}" Text="点击次数" />
                                    <TextBox Grid.Row="1" Grid.Column="0" Margin="0,4,0,0"
                                             Text="{Binding SelectedStepName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBox Grid.Row="1" Grid.Column="2" Margin="0,4,0,0"
                                             Text="{Binding MouseX, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBox Grid.Row="1" Grid.Column="4" Margin="0,4,0,0"
                                             Text="{Binding MouseY, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBox Grid.Row="1" Grid.Column="6" Margin="0,4,0,0"
                                             Text="{Binding MouseClickCount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Grid.Row="3" Grid.Column="0" Style="{StaticResource FormLabelStyle}" Text="点击间隔（毫秒）" />
                                    <TextBlock Grid.Row="3" Grid.Column="2" Style="{StaticResource FormLabelStyle}" Text="点击方式" />
                                    <TextBox Grid.Row="4" Grid.Column="0" Margin="0,4,0,0"
                                             Text="{Binding MouseClickIntervalMs, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <ComboBox Grid.Row="4" Grid.Column="2" Grid.ColumnSpan="3" Margin="0,4,0,0"
                                              ItemsSource="{Binding ClickTypeOptions}"
                                              DisplayMemberPath="DisplayName" SelectedValuePath="Value"
                                              SelectedValue="{Binding MouseClickType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </Grid>
                            </Grid>

                            <Border Grid.Column="4" Style="{StaticResource SubtleCardStyle}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="坐标采集" />
                                    <TextBlock Margin="0,6,0,6" FontSize="12"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               Text="{Binding CoordinateCaptureStatus}" />
                                    <TextBlock FontSize="20" FontWeight="Bold"
                                               Foreground="{StaticResource PrimaryBrush}"
                                               Text="{Binding LiveCursorPosition}" Margin="0,0,0,6" />
                                    <TextBlock FontWeight="SemiBold" FontSize="14"
                                               Foreground="{StaticResource PrimaryBrush}"
                                               Text="{Binding MouseClickTypeText}" />
                                    <Button Margin="0,14,0,0" Command="{Binding CaptureCoordinateCommand}"
                                            Content="选择坐标" Style="{StaticResource SecondaryButtonStyle}" />
                                    <Button Margin="0,8,0,0" Command="{Binding TestMouseClickCommand}"
                                            Content="测试点击一次" Style="{StaticResource SecondaryButtonStyle}" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </local:GlassCard>

                    <local:GlassCard Grid.Row="4" Style="{StaticResource CardStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="260" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Style="{StaticResource SectionTitleStyle}" Text="执行摘要" />
                                <TextBlock Margin="0,8,0,0" FontSize="13"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           Text="{Binding ExecutionSummary}" />
                                <TextBlock Margin="0,10,0,0" FontWeight="SemiBold" FontSize="13"
                                           Foreground="{StaticResource DangerBrush}"
                                           Text="{Binding ExecutionSafetyText}" />
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <Button Command="{Binding SaveTaskCommand}" Content="保存任务"
                                        Style="{StaticResource PrimaryButtonStyle}" />
                                <WrapPanel Margin="0,12,0,0">
                                    <Button Command="{Binding StartCommand}" Content="开始执行"
                                            Style="{StaticResource PrimaryButtonStyle}"
                                            Visibility="{Binding IsNotExecutionRunning, Converter={StaticResource BoolToVisibility}}" />
                                    <Button Command="{Binding PauseCommand}" Content="暂停"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Visibility="{Binding IsExecutionRunning, Converter={StaticResource BoolToVisibility}}" />
                                    <Button Command="{Binding ResumeCommand}" Content="继续"
                                            Style="{StaticResource PrimaryButtonStyle}"
                                            Visibility="{Binding IsExecutionPaused, Converter={StaticResource BoolToVisibility}}" />
                                    <Button Command="{Binding StopCommand}" Content="停止"
                                            Style="{StaticResource DangerButtonStyle}"
                                            Visibility="{Binding IsExecutionRunning, Converter={StaticResource BoolToVisibility}}" />
                                </WrapPanel>
                            </StackPanel>
                        </Grid>
                    </local:GlassCard>
                </Grid>
            </Grid>
        </ScrollViewer>
    </Grid>
</Window>
