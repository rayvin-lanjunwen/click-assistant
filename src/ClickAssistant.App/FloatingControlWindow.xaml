<Window x:Class="ClickAssistant.App.FloatingControlWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Click Assistant 控制"
        Width="300"
        SizeToContent="Height"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowActivated="False"
        ShowInTaskbar="False"
        Visibility="{Binding IsFloatingWindowVisible, Converter={StaticResource BoolToVisibility}}">
    <Window.Resources>
        <!-- 颜色与共享转换器已迁移到 App.xaml -->

        <!-- 共享缓动函数（独立窗口无法访问 MainWindow 的资源） -->
        <BackEase x:Key="EaseOutBack" EasingMode="EaseOut" Amplitude="0.3" />

        <!-- 液态玻璃三阶阴影 - L3 深层：悬浮窗 -->
        <DropShadowEffect x:Key="ShadowLg"
                          BlurRadius="32" ShadowDepth="14" Direction="270"
                          Color="#26334A" Opacity="0.18" />

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="FontFamily" Value="Microsoft YaHei UI" />
        </Style>

        <Style x:Key="FloatingButtonStyle" TargetType="Button">
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="Margin" Value="0,0,6,0" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="Background" Value="#BFFFFFFF" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryFloatingButtonStyle" TargetType="Button" BasedOn="{StaticResource FloatingButtonStyle}">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="{DynamicResource PrimaryGradientBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource PrimaryDarkBrush}" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>

        <Style x:Key="DangerFloatingButtonStyle" TargetType="Button" BasedOn="{StaticResource FloatingButtonStyle}">
            <Setter Property="Foreground" Value="{StaticResource DangerBrush}" />
            <Setter Property="BorderBrush" Value="#FECACA" />
        </Style>
    </Window.Resources>

    <Grid MouseLeftButtonDown="HandleMouseLeftButtonDown">
        <!-- 收起态 -->
        <Border Padding="12" CornerRadius="16"
                Background="{DynamicResource BgCardBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                Visibility="{Binding IsFloatingCollapsedVisible, Converter={StaticResource BoolToVisibility}}"
                Effect="{DynamicResource ShadowLg}">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Command="{Binding StopCommand}" Content="⏹"
                            Style="{StaticResource DangerFloatingButtonStyle}"
                            Visibility="{Binding IsExecutionRunning, Converter={StaticResource BoolToVisibility}}"
                            MinHeight="28" Padding="6,0,6,0" Margin="0,0,4,0" />
                    <Button Command="{Binding ToggleFloatingWindowCommand}"
                            Content="展开" Style="{StaticResource PrimaryFloatingButtonStyle}" />
                </StackPanel>
                <StackPanel Margin="0,0,8,0">
                    <TextBlock FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"
                               Text="Click Assistant" />
                    <TextBlock FontSize="15" FontWeight="SemiBold"
                               Foreground="{StaticResource PrimaryBrush}"
                               Text="{Binding StatusText}" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- 展开态 -->
        <Border Padding="16" CornerRadius="16"
                Background="{DynamicResource BgCardBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                Visibility="{Binding IsFloatingExpandedVisible, Converter={StaticResource BoolToVisibility}}"
                Effect="{DynamicResource ShadowLg}"
                RenderTransformOrigin="0.5,0">
            <Border.RenderTransform>
                <ScaleTransform />
            </Border.RenderTransform>
            <Border.Triggers>
                <EventTrigger RoutedEvent="Border.Loaded">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY"
                                             From="0" To="1"
                                             Duration="0:0:0.2"
                                             EasingFunction="{StaticResource EaseOutBack}" />
                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                             From="0" To="1"
                                             Duration="0:0:0.15" />
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Border.Triggers>
            <StackPanel>
                <DockPanel>
                    <Button DockPanel.Dock="Right"
                            Command="{Binding ToggleFloatingWindowCommand}"
                            Content="收起" Style="{StaticResource FloatingButtonStyle}" />
                    <StackPanel>
                        <TextBlock FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"
                                   Text="Click Assistant 控制" />
                        <TextBlock FontSize="18" FontWeight="SemiBold"
                                   Foreground="{StaticResource PrimaryBrush}"
                                   Text="{Binding StatusText}" />
                    </StackPanel>
                </DockPanel>

                <Border Margin="0,10,0,10" Padding="12" CornerRadius="10"
                        Background="{DynamicResource GlassSubtleBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock FontWeight="SemiBold" Text="{Binding FloatingTaskName}" />
                        <TextBlock Margin="0,4,0,0" FontSize="12"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   Text="{Binding FloatingTaskSummary}" />
                    </StackPanel>
                </Border>

                <WrapPanel>
                    <Button Command="{Binding PauseCommand}" Content="暂停"
                            Style="{StaticResource FloatingButtonStyle}"
                            Visibility="{Binding IsExecutionRunning, Converter={StaticResource BoolToVisibility}}" />
                    <Button Command="{Binding ResumeCommand}" Content="继续"
                            Style="{StaticResource PrimaryFloatingButtonStyle}"
                            Visibility="{Binding IsExecutionPaused, Converter={StaticResource BoolToVisibility}}" />
                    <Button Command="{Binding StopCommand}" Content="停止"
                            Style="{StaticResource DangerFloatingButtonStyle}"
                            Visibility="{Binding IsExecutionRunning, Converter={StaticResource BoolToVisibility}}" />
                </WrapPanel>
            </StackPanel>
        </Border>
    </Grid>
</Window>
